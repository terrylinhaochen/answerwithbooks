---
import AnswerCover from './AnswerCover.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  answer: CollectionEntry<'answers'>;
  bookTitles: Map<string, string>;
  compact?: boolean;
}
const { answer, bookTitles, compact = false } = Astro.props;
const sourceBooks = answer.data.books
  .map((slug) => ({ slug, title: bookTitles.get(slug) }))
  .filter((book) => book.title);
const cleanPreview = (value: string) =>
  value
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`>#]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
const bodyPreview = String(answer.body ?? '')
  .split(/\n{2,}/)
  .map((block) => block.trim())
  .filter((block) => block && !block.startsWith('#') && !block.startsWith('- ') && !/^\d+\./.test(block))
  .map(cleanPreview)
  .slice(0, 1);
const previewParagraphs = compact
  ? [answer.data.description]
  : bodyPreview.length > 0
    ? bodyPreview
    : [answer.data.description];
---

<article class={`awb-card-link group flex h-full flex-col ${compact ? 'p-4' : 'p-5'}`}>
  <AnswerCover answer={answer} class={compact ? 'mb-4' : 'mb-5'} />
  <div class="flex min-w-0 flex-1 flex-col self-stretch">
    <h3 class={`font-serif leading-snug ${compact ? 'text-xl' : 'text-2xl'}`}>
      <a href={`/answers/${answer.id}/`} class="inline-flex min-h-8 items-center hover:text-soft">{answer.data.question}</a>
    </h3>
    {
      sourceBooks.length > 0 && !compact && (
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <span class="font-sans text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-faint">
            Sources
          </span>
          {sourceBooks.map((book) => (
            <a
              href={`/books/${book.slug}/`}
              class="inline-flex min-h-8 max-w-full items-center rounded-full border border-line px-2.5 py-1 font-sans text-xs text-soft transition-colors hover:border-ink hover:text-ink"
            >
              {book.title}
            </a>
          ))}
        </div>
      )
    }
    <div class={`answer-row__preview mt-3 text-soft leading-relaxed ${compact ? 'text-[0.95rem]' : 'space-y-3'}`}>
      {previewParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</article>

<style>
  .answer-row__preview {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }
</style>
