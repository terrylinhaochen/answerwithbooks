---
import type { CollectionEntry } from 'astro:content';

interface Props {
  answer: CollectionEntry<'answers'>;
  bookTitles: Map<string, string>;
}
const { answer, bookTitles } = Astro.props;
const sourceTitles = answer.data.books
  .map((slug) => bookTitles.get(slug))
  .filter(Boolean)
  .join(' + ');
const sourceCount = answer.data.books.length;
const miniPalettes = [
  { cover: '#243b53', band: '#f0b35d', ink: '#fff7e8' },
  { cover: '#5c2f45', band: '#8fc6a3', ink: '#fff3ec' },
  { cover: '#214a43', band: '#d7a84d', ink: '#f8f2df' },
];
const sourceBooks = answer.data.books.slice(0, 3).map((slug, index) => {
  const title = bookTitles.get(slug) ?? 'Book';
  return {
    title,
    shortTitle: title.split(/\s+/).slice(0, 2).join(' '),
    palette: miniPalettes[index % miniPalettes.length],
  };
});
---

<article class="group rounded-md border border-line bg-white/55 p-5 shadow-sm transition-colors hover:border-accent/45">
  <div class="flex items-start gap-4">
    <div class="answer-icon hidden shrink-0 sm:block" aria-hidden="true">
      {sourceBooks.map(({ shortTitle, palette }, index) => (
        <span
          class="answer-icon__book"
          style={`--mini-cover:${palette.cover};--mini-band:${palette.band};--mini-ink:${palette.ink};left:${index * 13}px;transform:rotate(${(index - 1) * 4}deg);`}
        >
          <span class="answer-icon__title">{shortTitle}</span>
          <span class="answer-icon__band"></span>
        </span>
      ))}
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-xs uppercase tracking-[0.16em] text-faint font-sans">
        Local answer · {sourceCount} {sourceCount === 1 ? 'book' : 'books'}
      </p>
      <h3 class="mt-2 font-serif text-2xl font-semibold tracking-tight leading-snug">
        <a href={`/answers/${answer.id}/`} class="hover:text-accent">{answer.data.question}</a>
      </h3>
      {sourceTitles && <p class="mt-2 text-sm text-faint">Global books: {sourceTitles}</p>}
      <p class="mt-3 text-soft leading-relaxed">{answer.data.description}</p>
      <p class="mt-4 text-sm font-sans">
        <a href={`/answers/${answer.id}/`} class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
          Read the localized answer
        </a>
      </p>
    </div>
  </div>
</article>

<style>
  .answer-icon {
    position: relative;
    width: 4.25rem;
    height: 5.25rem;
  }

  .answer-icon__book {
    position: absolute;
    bottom: 0;
    display: block;
    width: 2.65rem;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--mini-cover) 72%, white);
    border-radius: 4px;
    background: var(--mini-cover);
    box-shadow:
      0 12px 24px rgb(34 30 26 / 0.12),
      inset 6px 0 0 rgb(0 0 0 / 0.12),
      inset 7px 0 0 rgb(255 255 255 / 0.08);
  }

  .answer-icon__book::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, transparent 0 42%, rgb(255 255 255 / 0.15) 42% 50%, transparent 50%),
      radial-gradient(circle at 72% 15%, rgb(255 255 255 / 0.18), transparent 25%);
  }

  .answer-icon__title {
    position: absolute;
    z-index: 1;
    top: 0.55rem;
    left: 0.55rem;
    right: 0.35rem;
    color: var(--mini-ink);
    font-family: var(--font-serif);
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 0.95;
  }

  .answer-icon__band {
    position: absolute;
    z-index: 1;
    right: 0;
    bottom: 1rem;
    left: 0;
    height: 0.46rem;
    background: var(--mini-band);
  }
</style>
