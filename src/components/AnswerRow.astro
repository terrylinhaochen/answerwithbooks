---
import type { CollectionEntry } from 'astro:content';

interface Props {
  answer: CollectionEntry<'answers'>;
  bookTitles: Map<string, string>;
}
const { answer, bookTitles } = Astro.props;
const sourceTitles = answer.data.books
  .map((slug) => bookTitles.get(slug))
  .filter(Boolean)
  .join(' · ');
---

<article class="py-7 border-b border-line last:border-b-0">
  <h3 class="font-serif text-2xl font-semibold tracking-tight leading-snug">
    <a href={`/answers/${answer.id}/`} class="hover:text-accent">{answer.data.question}</a>
  </h3>
  {sourceTitles && <p class="mt-1 text-sm text-faint">Drawing on {sourceTitles}</p>}
  <p class="mt-3 text-soft leading-relaxed max-w-prose">{answer.data.description}</p>
  <p class="mt-3 text-sm">
    <a href={`/answers/${answer.id}/`} class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
      Read the answer
    </a>
  </p>
</article>
