---
import type { CollectionEntry } from 'astro:content';
import BookCover from './BookCover.astro';
import { topicsForTags } from '../lib/topics';

interface Props {
  book: CollectionEntry<'books'>;
  compact?: boolean;
}
const { book, compact = false } = Astro.props;
const topics = topicsForTags(book.data.tags);
---

<article class={`group h-full rounded-2xl border border-line bg-card shadow-sm transition-colors hover:border-ink/25 ${compact ? 'p-5' : 'p-4'}`}>
  <div class={compact ? 'flex h-full flex-col gap-5' : 'grid h-full grid-cols-[4.5rem_minmax(0,1fr)] gap-4 sm:grid-cols-[5rem_minmax(0,1fr)]'}>
    <BookCover book={book} size={compact ? 'lg' : 'sm'} class={compact ? 'mx-auto' : 'shrink-0'} />
    <div class="flex min-w-0 flex-1 flex-col">
      <p class="text-xs font-semibold uppercase tracking-[0.08em] text-faint font-sans">Source book</p>
      <h3 class={`mt-1 text-wrap font-serif tracking-[-0.01em] leading-snug ${compact ? 'text-2xl' : 'text-2xl'}`}>
        <a href={`/books/${book.id}/`} class="hover:text-soft">{book.data.title}</a>
      </h3>
      <p class="mt-1 text-sm text-faint">
        {book.data.author} · {book.data.year}
      </p>
      <p class={`book-row__copy mt-3 text-soft leading-relaxed ${compact ? 'text-[0.95rem]' : ''}`}>{book.data.oneLiner}</p>
      <div class="mt-auto flex flex-wrap gap-2 pt-4">
        {topics.slice(0, 3).map((topic) => (
          <a
            href={`/topics/${topic.slug}/`}
            class="max-w-full rounded-full border border-line px-2.5 py-1 text-xs text-soft font-sans hover:border-ink hover:text-ink"
          >
            {topic.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</article>

<style>
  .book-row__copy {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
</style>
