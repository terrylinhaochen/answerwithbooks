---
import type { CollectionEntry } from 'astro:content';

interface Props {
  book: CollectionEntry<'books'>;
}
const { book } = Astro.props;
---

<article class="py-7 border-b border-line last:border-b-0">
  <h3 class="font-serif text-2xl font-semibold tracking-tight leading-snug">
    <a href={`/books/${book.id}/`} class="hover:text-accent">{book.data.title}</a>
  </h3>
  <p class="mt-1 text-sm text-faint">
    {book.data.author} · {book.data.year}
  </p>
  <p class="mt-3 text-soft leading-relaxed max-w-prose">{book.data.oneLiner}</p>
  <p class="mt-3 text-sm">
    <a href={`/books/${book.id}/`} class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
      Read the distillation
    </a>
  </p>
</article>
