---
import type { CollectionEntry } from 'astro:content';
import BookCover from './BookCover.astro';
import { topicsForTags } from '../lib/topics';

interface Props {
  book: CollectionEntry<'books'>;
}
const { book } = Astro.props;
const topics = topicsForTags(book.data.tags);
---

<article class="group rounded-md border border-line bg-white/45 p-4 shadow-sm transition-colors hover:border-accent/45">
  <div class="grid grid-cols-[4.5rem_minmax(0,1fr)] gap-4 sm:grid-cols-[5rem_minmax(0,1fr)]">
    <BookCover book={book} size="sm" class="shrink-0" />
    <div class="min-w-0 flex-1">
      <p class="text-xs uppercase tracking-[0.16em] text-faint font-sans">Source book</p>
      <h3 class="mt-1 text-wrap font-serif text-2xl font-semibold tracking-tight leading-snug">
        <a href={`/books/${book.id}/`} class="hover:text-accent">{book.data.title}</a>
      </h3>
      <p class="mt-1 text-sm text-faint">
        {book.data.author} · {book.data.year}
      </p>
      <p class="mt-3 text-soft leading-relaxed">{book.data.oneLiner}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {topics.slice(0, 3).map((topic) => (
          <a
            href={`/topics/${topic.slug}/`}
            class="max-w-full rounded-full border border-line px-2.5 py-1 text-xs text-soft font-sans hover:border-accent hover:text-accent"
          >
            {topic.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</article>
