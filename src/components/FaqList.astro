---
import type { FaqItem } from '../lib/seo';

interface Props {
  items: FaqItem[];
  eyebrow?: string;
  title?: string;
}

const {
  items,
  eyebrow = 'Questions answered',
  title = 'Quick Q&A',
} = Astro.props;
---

{
  items.length > 0 && (
    <section class="mx-auto max-w-3xl px-5 py-12">
      <div class="border-t border-line pt-8">
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">{eyebrow}</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight">{title}</h2>
        <div class="mt-6 grid gap-5">
          {items.map((item) => (
            <article class="rounded-md border border-line bg-white/55 p-5">
              <h3 class="font-serif text-xl font-semibold leading-snug">{item.question}</h3>
              <p class="mt-3 leading-relaxed text-soft">{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
