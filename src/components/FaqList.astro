---
import type { FaqItem } from '../lib/seo';

interface Props {
  items: FaqItem[];
  eyebrow?: string;
  title?: string;
  width?: 'article' | 'medium' | 'wide';
}

const {
  items,
  eyebrow = 'Questions answered',
  title = 'Quick Q&A',
  width = 'article',
} = Astro.props;

const widthClass =
  width === 'wide' ? 'max-w-6xl' : width === 'medium' ? 'max-w-5xl' : 'max-w-3xl';
---

{
  items.length > 0 && (
    <section class={`mx-auto ${widthClass} px-5 py-12`}>
      <div class="border-t border-line pt-8">
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-faint font-sans">{eyebrow}</p>
        <h2 class="mt-3 font-serif text-3xl tracking-[-0.015em]">{title}</h2>
        <div class="mt-6 grid gap-3">
          {items.map((item) => (
            <details class="group rounded-2xl border border-line bg-card">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4">
                <h3 class="font-serif text-xl leading-snug">{item.question}</h3>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-line font-sans text-sm text-faint transition-colors group-open:border-ink group-open:text-ink">
                  <span class="group-open:hidden">+</span>
                  <span class="hidden group-open:inline">-</span>
                </span>
              </summary>
              <p class="px-5 pb-5 leading-relaxed text-soft">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
