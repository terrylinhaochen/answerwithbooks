---
import { getCollection, render } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../../layouts/Base.astro';
import AnswerCover from '../../components/AnswerCover.astro';
import AnswerRow from '../../components/AnswerRow.astro';
import BookCover from '../../components/BookCover.astro';
import FaqList from '../../components/FaqList.astro';
import { topicsForTags } from '../../lib/topics';
import { compactList, faqJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const answers = await getCollection('answers');
  return answers.map((answer) => ({ params: { slug: answer.id }, props: { answer } }));
}

const { answer } = Astro.props;
const { Content } = await render(answer);
const topics = topicsForTags(answer.data.tags);

const allBooks = await getCollection('books');
const sourceBooks = answer.data.books
  .map((slug) => allBooks.find((b) => b.id === slug))
  .filter((b) => b !== undefined);
const sourceBookTitles = sourceBooks.map((book) => book.data.title);
const bookTitleMap = new Map(allBooks.map((book) => [book.id, book.data.title]));
const allAnswers = await getCollection('answers');
const relatedAnswers = allAnswers
  .filter((candidate) => candidate.id !== answer.id)
  .map((candidate) => {
    const sharedBooks = candidate.data.books.filter((book) => answer.data.books.includes(book)).length;
    const sharedTags = candidate.data.tags.filter((tag) => answer.data.tags.includes(tag)).length;
    return { candidate, score: sharedBooks * 2 + sharedTags };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.date.valueOf() - a.candidate.data.date.valueOf())
  .slice(0, 3)
  .map(({ candidate }) => candidate);

const dateFmt = answer.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const url = `https://answerwithbooks.com/answers/${answer.id}/`;
const answerCoverPath = fileURLToPath(new URL(`../../../public/answer-covers/${answer.id}.jpg`, import.meta.url));
const answerImage = existsSync(answerCoverPath) ? `/answer-covers/${answer.id}.jpg` : '/og.svg';
const breadcrumbs = [
  { name: 'Answer with Books', url: 'https://answerwithbooks.com/' },
  { name: 'Answers', url: 'https://answerwithbooks.com/answers/' },
  { name: answer.data.question, url },
];
const faqs = [
  {
    question: answer.data.question,
    answer: answer.data.description,
  },
  {
    question: 'Which books is this answer grounded in?',
    answer: `This answer draws on ${compactList(sourceBookTitles, 'the source shelf')} and links back to each source book for deeper reading.`,
  },
  {
    question: 'Who is this answer written for?',
    answer:
      'It is written for readers who want practical, book-grounded guidance they can use before a real decision.',
  },
];
const jsonLd = [
  {
    '@type': 'WebPage',
    '@id': `${url}#webpage`,
    url,
    name: answer.data.question,
    description: answer.data.description,
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    primaryImageOfPage: { '@id': `${url}#primaryimage` },
  },
  {
    '@type': 'ImageObject',
    '@id': `${url}#primaryimage`,
    url: new URL(answerImage, 'https://answerwithbooks.com').href,
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    mainEntityOfPage: { '@id': `${url}#webpage` },
    headline: answer.data.question,
    description: answer.data.description,
    datePublished: answer.data.date.toISOString(),
    dateModified: answer.data.date.toISOString(),
    image: new URL(answerImage, 'https://answerwithbooks.com').href,
    author: { '@type': 'Person', name: 'Terry Chen', url: 'https://terrylinhaochen.github.io' },
    publisher: { '@id': 'https://answerwithbooks.com/#person' },
    keywords: answer.data.tags,
    about: sourceBooks.map((book) => ({
      '@type': 'Book',
      name: book.data.title,
      author: { '@type': 'Person', name: book.data.author },
      url: `https://answerwithbooks.com/books/${book.id}/`,
    })),
    url,
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url,
    })),
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title={answer.data.question}
  description={answer.data.description}
  path={`/answers/${answer.id}/`}
  image={answerImage}
  imageAlt={`Answer card for ${answer.data.question}`}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-5xl px-5 pt-16 pb-16">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-soft">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-accent">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/answers/" class="hover:text-accent">Answers</a></li>
      </ol>
    </nav>

    <header class="grid gap-8 border-b border-line pb-10 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,28rem)] lg:items-start">
      <div>
        <p class="awb-eyebrow">Answer</p>
        <h1 class="mt-3 text-wrap break-words font-serif text-4xl leading-tight sm:text-5xl">
          {answer.data.question}
        </h1>
        <p class="mt-4 text-sm text-faint">
          <time datetime={answer.data.date.toISOString()}>{dateFmt}</time>
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-save-answer={answer.id}
            class="awb-pill awb-pill-outline cursor-pointer"
          >
            Save answer
          </button>
          <button
            type="button"
            data-like-answer={answer.id}
            class="awb-pill awb-pill-outline cursor-pointer"
          >
            Mark helpful
          </button>
          {topics.map((topic) => (
            <a
              href={`/topics/${topic.slug}/`}
              class="inline-flex min-h-8 items-center rounded-full border border-line px-3 py-1 text-xs text-soft font-sans hover:border-accent hover:text-accent"
            >
              {topic.label}
            </a>
          ))}
        </div>
      </div>
      <AnswerCover answer={answer} class="lg:mt-1" priority />
    </header>

    <section class="mt-6 grid gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]">
      <div class="awb-card-link p-6 text-[1rem] leading-relaxed">
        <h2 class="awb-eyebrow mb-3">
          Decision rule
        </h2>
        <p class="text-soft">{answer.data.description}</p>
      </div>

      <div class="awb-card-link p-5">
        <p class="awb-eyebrow">
          Source lens
        </p>
        <ul class="mt-4 space-y-4">
          {
            sourceBooks.map((book) => (
              <li class="flex items-center gap-4">
                <BookCover book={book} size="sm" />
                <div class="min-w-0">
                  <a
                    href={`/books/${book.id}/`}
                    class="font-serif text-xl leading-tight text-ink hover:text-accent"
                  >
                    {book.data.title}
                  </a>
                  <p class="mt-1 text-sm text-soft">{book.data.author}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="prose-awb prose-awb--aligned mt-10">
      <Content />
    </div>
  </article>

  <FaqList items={faqs} eyebrow="Answer Q&A" title="What this guide answers" width="medium" />

  {
    relatedAnswers.length > 0 && (
      <aside class="mx-auto max-w-5xl px-5 pb-16">
        <div class="border-t border-line pt-8">
          <h2 class="awb-eyebrow">
            Related guides
          </h2>
          <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {relatedAnswers.map((related) => (
              <AnswerRow answer={related} bookTitles={bookTitleMap} compact />
            ))}
          </div>
        </div>
      </aside>
    )
  }

  <script>
    import { LIKED_ANSWERS_KEY, SAVED_ANSWERS_KEY, readJson, toggleId } from '../../lib/user-library';

    const wireToggle = (selector: string, key: string, offText: string, onText: string) => {
      const button = document.querySelector<HTMLButtonElement>(selector);
      if (!button) return;
      const id = button.dataset.saveAnswer || button.dataset.likeAnswer;
      if (!id) return;

      const paint = () => {
        const active = readJson<string[]>(key, []).includes(id);
        button.textContent = active ? onText : offText;
        button.classList.toggle('awb-pill-primary', active);
        button.classList.toggle('awb-pill-outline', !active);
      };

      button.addEventListener('click', () => {
        toggleId(key, id);
        paint();
      });
      paint();
    };

    wireToggle('[data-save-answer]', SAVED_ANSWERS_KEY, 'Save answer', 'Saved - remove');
    wireToggle('[data-like-answer]', LIKED_ANSWERS_KEY, 'Mark helpful', 'Helpful');
  </script>
</Base>
