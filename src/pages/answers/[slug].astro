---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const answers = await getCollection('answers');
  return answers.map((answer) => ({ params: { slug: answer.id }, props: { answer } }));
}

const { answer } = Astro.props;
const { Content } = await render(answer);

const allBooks = await getCollection('books');
const sourceBooks = answer.data.books
  .map((slug) => allBooks.find((b) => b.id === slug))
  .filter((b) => b !== undefined);

const dateFmt = answer.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: answer.data.question,
  description: answer.data.description,
  datePublished: answer.data.date.toISOString(),
  author: { '@type': 'Person', name: 'Terry Chen', url: 'https://terrylinhaochen.github.io' },
  url: `https://answerwithbooks.com/answers/${answer.id}/`,
};
---

<Base
  title={answer.data.question}
  description={answer.data.description}
  path={`/answers/${answer.id}/`}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-5 pt-16 pb-16">
    <header class="pb-8 border-b border-line">
      <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Answer</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold tracking-tight leading-tight">
        {answer.data.question}
      </h1>
      <p class="mt-3 text-sm text-faint">
        <time datetime={answer.data.date.toISOString()}>{dateFmt}</time>
      </p>
    </header>

    <div class="mt-4 py-4 px-5 bg-wash rounded-sm text-[0.95rem] leading-relaxed">
      <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans mb-2">
        Answered with
      </p>
      <ul class="space-y-1">
        {
          sourceBooks.map((book) => (
            <li>
              <a
                href={`/books/${book.id}/`}
                class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark"
              >
                {book.data.title}
              </a>
              <span class="text-soft"> — {book.data.author}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="prose-awb mt-8">
      <Content />
    </div>
  </article>
</Base>
