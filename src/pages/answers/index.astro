---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AnswerRow from '../../components/AnswerRow.astro';
import FaqList from '../../components/FaqList.astro';
import { faqJsonLd } from '../../lib/seo';
import { CANONICAL_TOPICS, topicsForTags } from '../../lib/topics';

const answers = (await getCollection('answers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const books = await getCollection('books');
const bookTitles = new Map(books.map((b) => [b.id, b.data.title]));
const answerCategories = CANONICAL_TOPICS.map((topic) => ({
  slug: topic.slug,
  label: topic.label,
  description: topic.description,
  count: answers.filter((answer) => topicsForTags(answer.data.tags).some((answerTopic) => answerTopic.slug === topic.slug)).length,
}));
const url = 'https://answerwithbooks.com/answers/';
const faqs = [
  {
    question: 'What makes these answers different from normal book summaries?',
    answer:
      'Each answer starts with a specific reader problem and then uses books as source material. The goal is a useful decision rule or next step, not a chapter-by-chapter summary.',
  },
  {
    question: 'How are answers chosen?',
    answer:
      'Answers are chosen from recurring practical questions, then matched to books that can make the answer more useful than generic advice.',
  },
  {
    question: 'How many books does each answer use?',
    answer:
      'Most answers draw on one to three books so the synthesis stays focused and the source trail remains easy to inspect.',
  },
];
const jsonLd = [
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    url,
    name: 'Answer with Books guides',
    description:
      'Practical how-to guides that answer recurring internet questions with frameworks from books.',
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    mainEntity: { '@id': `${url}#itemlist` },
  },
  {
    '@type': 'ItemList',
    '@id': `${url}#itemlist`,
    itemListElement: answers.map((answer, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: answer.data.question,
      url: `https://answerwithbooks.com/answers/${answer.id}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Answer with Books', item: 'https://answerwithbooks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Answers', item: url },
    ],
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title="Answers"
  description="Real questions, answered with books: startup validation, team decisions, failed plans, pivots, and intuition — each answer grounded in distilled reading."
  path="/answers/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-8">
    <p class="text-xs uppercase tracking-[0.18em] text-accent font-sans">Insight library</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold tracking-tight">Book-grounded insights</h1>
    <p class="mt-4 text-soft leading-relaxed max-w-2xl">
      Practical insights from recurring demand signals, grounded in one to three books from
      <a href="/books/" class="text-accent underline underline-offset-4 decoration-1">the shelf</a>.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-6">
    <div class="border-y border-line bg-wash/60 p-4 sm:p-5" data-answer-filter>
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <label class="block min-w-0 lg:w-[26rem]">
          <span class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Search insights</span>
          <input
            type="search"
            placeholder="Search business, technology, productivity, decisions..."
            class="mt-2 w-full border border-line bg-paper px-3 py-2.5 font-serif text-base text-ink outline-none transition-colors placeholder:text-faint focus:border-accent"
            data-filter-search
          />
        </label>
        <button
          type="button"
          class="w-fit border border-ink bg-ink px-4 py-2.5 font-sans text-xs uppercase tracking-[0.14em] text-paper"
          data-filter-category="all"
        >
          All insights
        </button>
      </div>

      <div class="mt-6">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Browse by category</p>
            <p class="mt-1 text-sm text-soft">Broad paths into the shelf and insight library.</p>
          </div>
          <p class="text-sm text-faint" data-filter-count>{answers.length} insights</p>
        </div>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" aria-label="Browse answers by category">
          {answerCategories.map((category) => (
            <button
              type="button"
              class="group flex min-h-[8.75rem] flex-col rounded-md border border-line bg-paper/70 p-4 text-left transition-colors hover:border-accent/55"
              data-filter-category={category.slug}
            >
              <span class="font-sans text-xs uppercase tracking-[0.16em] text-faint">{category.count} insights</span>
              <span class="mt-2 font-serif text-xl font-semibold leading-tight group-hover:text-accent">{category.label}</span>
              <span class="mt-2 text-sm leading-relaxed text-soft">{category.description}</span>
            </button>
          ))}
        </div>
        <p class="mt-3 hidden text-sm text-faint" data-filter-empty>No insights match this view.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-16 pt-2">
    <div class="grid items-stretch gap-4 md:grid-cols-2" data-filter-list>
      {answers.map((answer) => (
        <div
          class="h-full"
          data-filter-item
          data-tags={JSON.stringify(answer.data.tags)}
          data-categories={JSON.stringify(topicsForTags(answer.data.tags).map((topic) => topic.slug))}
          data-search={`${answer.data.question} ${answer.data.description} ${answer.data.tags.join(' ')} ${answer.data.books.map((slug) => bookTitles.get(slug) ?? slug).join(' ')}`.toLowerCase()}
        >
          <AnswerRow answer={answer} bookTitles={bookTitles} />
        </div>
      ))}
    </div>
    <div
      class="mt-6 flex flex-col gap-3 border-t border-line pt-5 text-sm text-soft sm:flex-row sm:items-center sm:justify-between"
      data-pagination
    >
      <p data-pagination-summary>Showing all insights</p>
      <div class="flex items-center gap-3">
        <button
          type="button"
          class="border border-line bg-paper px-3 py-2 font-sans text-xs uppercase tracking-[0.14em] text-soft transition-colors hover:border-accent hover:text-accent disabled:cursor-not-allowed disabled:opacity-35 disabled:hover:border-line disabled:hover:text-soft"
          data-pagination-prev
        >
          Previous
        </button>
        <span class="font-sans text-xs uppercase tracking-[0.14em] text-faint" data-pagination-page>Page 1 of 1</span>
        <button
          type="button"
          class="border border-line bg-paper px-3 py-2 font-sans text-xs uppercase tracking-[0.14em] text-soft transition-colors hover:border-accent hover:text-accent disabled:cursor-not-allowed disabled:opacity-35 disabled:hover:border-line disabled:hover:text-soft"
          data-pagination-next
        >
          Next
        </button>
      </div>
    </div>
  </section>
  <FaqList items={faqs} eyebrow="Answer Q&A" title="How these guides work" width="wide" />

  <script>
    const root = document.querySelector<HTMLElement>('[data-answer-filter]');
    const list = document.querySelector<HTMLElement>('[data-filter-list]');
    const search = root?.querySelector<HTMLInputElement>('[data-filter-search]');
    const buttons = Array.from(root?.querySelectorAll<HTMLButtonElement>('[data-filter-category]') ?? []);
    const count = root?.querySelector<HTMLElement>('[data-filter-count]');
    const empty = root?.querySelector<HTMLElement>('[data-filter-empty]');
    const items = Array.from(list?.querySelectorAll<HTMLElement>('[data-filter-item]') ?? []);
    const pageSize = 8;
    let activeCategory = 'all';
    let currentPage = 1;

    const pagination = document.querySelector<HTMLElement>('[data-pagination]');
    const paginationSummary = pagination?.querySelector<HTMLElement>('[data-pagination-summary]');
    const paginationPage = pagination?.querySelector<HTMLElement>('[data-pagination-page]');
    const previous = pagination?.querySelector<HTMLButtonElement>('[data-pagination-prev]');
    const next = pagination?.querySelector<HTMLButtonElement>('[data-pagination-next]');

    const render = () => {
      const query = search?.value.trim().toLowerCase() ?? '';
      const matches = items.filter((item) => {
        const categories = JSON.parse(item.dataset.categories ?? '[]') as string[];
        const matchesCategory = activeCategory === 'all' || categories.includes(activeCategory);
        const matchesQuery = !query || item.dataset.search?.includes(query);
        return Boolean(matchesCategory && matchesQuery);
      });
      const total = matches.length;
      const pageCount = Math.max(1, Math.ceil(total / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = total === 0 ? 0 : (currentPage - 1) * pageSize;
      const end = Math.min(start + pageSize, total);
      const pageItems = new Set(matches.slice(start, end));

      for (const item of items) item.hidden = !pageItems.has(item);

      if (count) count.textContent = `${total} insight${total === 1 ? '' : 's'}`;
      if (empty) empty.classList.toggle('hidden', total > 0);
      if (pagination) pagination.hidden = total <= pageSize;
      if (paginationSummary) {
        paginationSummary.textContent =
          total === 0 ? 'No insights found' : `Showing ${start + 1}-${end} of ${total} insights`;
      }
      if (paginationPage) paginationPage.textContent = `Page ${currentPage} of ${pageCount}`;
      if (previous) previous.disabled = currentPage <= 1;
      if (next) next.disabled = currentPage >= pageCount;
      for (const button of buttons) {
        const isActive = button.dataset.filterCategory === activeCategory;
        button.classList.toggle('bg-ink', isActive);
        button.classList.toggle('text-paper', isActive);
        button.classList.toggle('border-ink', isActive);
        button.classList.toggle('bg-paper/70', !isActive);
        button.classList.toggle('text-soft', !isActive);
        button.classList.toggle('border-line', !isActive);
      }
    };

    const resetAndRender = () => {
      currentPage = 1;
      render();
    };

    search?.addEventListener('input', resetAndRender);
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextCategory = button.dataset.filterCategory ?? 'all';
        activeCategory = nextCategory === activeCategory ? 'all' : nextCategory;
        resetAndRender();
      });
    });
    previous?.addEventListener('click', () => {
      currentPage -= 1;
      render();
    });
    next?.addEventListener('click', () => {
      currentPage += 1;
      render();
    });
    render();
  </script>
</Base>
