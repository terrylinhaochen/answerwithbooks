---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AnswerRow from '../../components/AnswerRow.astro';
import FaqList from '../../components/FaqList.astro';
import { glocal } from '../../lib/glocal';
import { faqJsonLd } from '../../lib/seo';

const answers = (await getCollection('answers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const books = await getCollection('books');
const bookTitles = new Map(books.map((b) => [b.id, b.data.title]));
const url = 'https://answerwithbooks.com/answers/';
const faqs = [
  {
    question: 'What makes these answers different from normal book summaries?',
    answer:
      'Each answer starts with a specific reader problem and then uses books as source material. The goal is a useful decision rule or next step, not a chapter-by-chapter summary.',
  },
  {
    question: 'Are these answers written for Japanese and Korean readers?',
    answer:
      'Yes. The site is English-first today, but the content strategy prioritizes Japanese and Korean demand, examples, and constraints.',
  },
  {
    question: 'How many books does each answer use?',
    answer:
      'Most answers draw on one to three books so the synthesis stays focused and the source trail remains easy to inspect.',
  },
];
const jsonLd = [
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    url,
    name: 'Answer with Books guides',
    description:
      'Practical how-to guides for Japanese and Korean readers, grounded in frameworks from books.',
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    mainEntity: { '@id': `${url}#itemlist` },
  },
  {
    '@type': 'ItemList',
    '@id': `${url}#itemlist`,
    itemListElement: answers.map((answer, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: answer.data.question,
      url: `https://answerwithbooks.com/answers/${answer.id}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Answer with Books', item: 'https://answerwithbooks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Answers', item: url },
    ],
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title="Answers"
  description={`Real questions from ${glocal.audience}, answered with books: career, relationships, health, technology, business, negotiation, productivity, and decisions.`}
  path="/answers/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-8">
    <p class="text-xs uppercase tracking-[0.18em] text-accent font-sans">Localized synthesis</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold tracking-tight">Answers for Japan and Korea</h1>
    <p class="mt-4 text-soft leading-relaxed max-w-2xl">
      Practical questions answered by putting books to work. Each guide draws on one to three titles
      from <a href="/books/" class="text-accent underline underline-offset-4 decoration-1">the shelf</a>,
      then adapts the idea to local work, family, business, and technology contexts.
    </p>
  </section>
  <section class="mx-auto max-w-6xl px-5 pb-16 pt-6 border-t border-line">
    <div class="grid gap-4 md:grid-cols-2">
      {answers.map((answer) => <AnswerRow answer={answer} bookTitles={bookTitles} />)}
    </div>
  </section>
  <FaqList items={faqs} eyebrow="Answer Q&A" title="How these guides work" />
</Base>
