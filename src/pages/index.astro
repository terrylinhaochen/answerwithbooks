---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BookCover from '../components/BookCover.astro';
import BookRow from '../components/BookRow.astro';
import AnswerRow from '../components/AnswerRow.astro';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const answers = (await getCollection('answers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredBooks = books.filter((b) => b.data.featured).slice(0, 4);
const featuredAnswers = answers.filter((a) => a.data.featured).slice(0, 3);
const bookTitles = new Map(books.map((b) => [b.id, b.data.title]));
const installCommand = 'npx answer-with-books install --skill --api';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Answer with Books',
  url: 'https://answerwithbooks.com/',
  description:
    "The internet's top questions, answered with books. Turn source books into a collective skill for your chat AI and apps.",
  author: { '@type': 'Person', name: 'Terry Chen', url: 'https://terrylinhaochen.github.io' },
};
---

<Base
  title="Answer with Books — the internet's top questions, answered with books"
  description="The internet's top questions, answered with books. Turn source books into a collective skill for your chat AI and apps."
  path="/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-[1440px] px-5 pb-16 pt-14 sm:px-8 sm:pt-18 lg:px-20 lg:pb-24 lg:pt-24 xl:px-[120px]">
    <div class="grid min-w-0 grid-cols-1 items-center gap-12 xl:grid-cols-[0.95fr_1.05fr] xl:gap-20">
      <div class="min-w-0">
        <p class="max-w-[20rem] font-sans text-xs uppercase leading-relaxed tracking-[0.18em] text-accent sm:max-w-none">
          Internet questions, book-grounded answers.
        </p>
        <h1 class="mt-5 max-w-[12ch] break-words font-serif text-[2.75rem] font-semibold leading-[1.03] tracking-tight sm:max-w-4xl sm:text-6xl lg:text-7xl">
          The internet's top questions, answered with books.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-soft">
          Answer with Books compiles the questions people keep asking online, then turns them into
          grounded answers using durable ideas, quotes, and frameworks from books. Bring your own
          shelf to make the books you have read callable inside your chat AI.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4 text-[0.95rem]">
          <a
            href="/answers/"
            class="bg-ink text-paper px-5 py-2.5 rounded-sm hover:bg-accent transition-colors"
          >
            Explore answers
          </a>
          <a href="/books/" class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
            Browse source books
          </a>
        </div>
      </div>

      <div class="min-w-0 rounded-lg border border-line bg-white/55 p-4 shadow-sm sm:p-6">
        <div class="rounded-md border border-line bg-paper p-5">
          <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Internet question</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold leading-tight sm:text-3xl">
            Am I validating this idea or just collecting compliments?
          </h2>
        </div>

        <div class="mt-5 grid min-w-0 grid-cols-1 gap-4">
          <div class="rounded-md border border-line bg-wash/80 p-5">
            <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Book synthesis</p>
            <div class="mt-4 grid gap-5">
              <div class="flex items-end justify-center gap-3">
                {featuredBooks.slice(0, 3).map((book, index) => (
                  <BookCover
                    book={book}
                    size={index === 1 ? 'lg' : 'md'}
                    class={index === 1 ? 'relative z-10' : 'relative'}
                  />
                ))}
              </div>
              <p class="max-w-2xl text-base leading-relaxed text-soft">
                The Mom Test, Thinking, Fast and Slow, and The Wisdom of Crowds become lenses for
                separating real demand from politeness, optimism, and groupthink.
              </p>
            </div>
          </div>

          <div class="rounded-md border border-line bg-ink p-5 text-paper">
            <p class="font-sans text-xs uppercase tracking-[0.18em] text-paper/55">Answer path</p>
            <div class="mt-5 grid gap-4 sm:grid-cols-3">
              {[
                ['1', 'Separate excitement from evidence.'],
                ['2', 'Use past behavior, not praise.'],
                ['3', 'Turn uncertainty into the next test.'],
              ].map(([number, text]) => (
                <div class="grid grid-cols-[2rem_1fr] gap-3">
                  <span class="flex h-8 w-8 items-center justify-center rounded-full border border-white/15 font-sans text-sm text-paper/80">
                    {number}
                  </span>
                  <p class="min-w-0 font-serif text-lg font-semibold leading-tight">{text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-5 rounded-md border border-line bg-paper p-5">
          <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Book-grounded answer</p>
          <p class="mt-3 text-base leading-relaxed text-soft">
            The answer is not "trust your gut" or "ask users if they like it." It is to use books as
            lenses: test for real behavior, compare against base rates, and make the next move small
            enough that reality can answer back.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-wash/70">
    <div class="mx-auto grid max-w-[1440px] grid-cols-1 gap-4 px-5 py-8 sm:px-8 md:grid-cols-3 lg:px-20 xl:px-[120px]">
      <div class="rounded-md bg-paper p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Ask</p>
        <p class="mt-2 font-serif text-2xl font-semibold">Compile the questions people keep asking.</p>
      </div>
      <div class="rounded-md bg-paper p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Synthesize</p>
        <p class="mt-2 font-serif text-2xl font-semibold">Pull the strongest ideas across books.</p>
      </div>
      <div class="rounded-md bg-paper p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Apply</p>
        <p class="mt-2 font-serif text-2xl font-semibold">Turn insight into your next useful move.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-5 py-16 sm:px-8 lg:px-20 xl:px-[120px]">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[0.95fr_1.05fr] xl:gap-16">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">How it works</p>
        <div class="mt-6 grid gap-5">
          <div class="grid grid-cols-[3rem_1fr] gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md border border-line bg-wash text-accent">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 6.5c2-1.2 5.2-1.2 8 1v11c-2.8-2.2-6-2.2-8-1z" />
                <path d="M12 7.5c2.8-2.2 6-2.2 8-1v11c-2-1.2-5.2-1.2-8 1z" />
                <path d="M12 7.5v11" />
              </svg>
            </div>
            <div>
              <h2 class="font-serif text-2xl font-semibold leading-tight tracking-tight">1. Add a book</h2>
              <p class="mt-2 max-w-xl leading-relaxed text-soft">
                A title is enough to start. Books earn their page through a real reading - no
                summaries of summaries.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-[3rem_1fr] gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md border border-line bg-wash text-accent">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 3h6" />
                <path d="M10 3v5l-5 9a3 3 0 0 0 2.6 4.5h8.8A3 3 0 0 0 19 17l-5-9V3" />
                <path d="M8 15h8" />
              </svg>
            </div>
            <div>
              <h2 class="font-serif text-2xl font-semibold leading-tight tracking-tight">2. Distill into a skill</h2>
              <p class="mt-2 max-w-xl leading-relaxed text-soft">
                Each book is reduced to its load-bearing ideas - mental models, frameworks, when to
                reach for them - packaged as a callable skill.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-[3rem_1fr] gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md border border-line bg-wash text-accent">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m8 8-4 4 4 4" />
                <path d="m16 8 4 4-4 4" />
                <path d="m14 4-4 16" />
              </svg>
            </div>
            <div>
              <h2 class="font-serif text-2xl font-semibold leading-tight tracking-tight">3. Call it anywhere</h2>
              <p class="mt-2 max-w-xl leading-relaxed text-soft">
                Ask a real question and the right books answer - on this site, as a chat AI skill, or
                over the REST API.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-md border border-line bg-wash p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Your shelf, callable</p>
        <h2 class="mt-3 font-serif text-4xl font-semibold leading-tight tracking-tight">
          Turn your books into one collective chat skill.
        </h2>
        <p class="mt-4 max-w-2xl leading-relaxed text-soft">
          Add the books you've read and they become skills you can query - from this site, from your
          chat AI, from your agent of choice, or programmatically. Create a free account to add your
          first books; skill and REST API access is rolling out to early accounts.
        </p>
        <p class="mt-6">
          <a
            href="/signup/"
            class="bg-ink text-paper px-5 py-2.5 rounded-sm hover:bg-accent transition-colors text-[0.95rem]"
          >
            Add a book
          </a>
        </p>
        <div class="mt-8">
          <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Skill + REST API install</p>
          <pre class="mt-3 overflow-x-auto rounded-md bg-ink px-4 py-3 text-[0.9rem] leading-relaxed text-paper"><code class="whitespace-nowrap">{installCommand}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-5 py-16 sm:px-8 lg:px-20 xl:px-[120px]">
    <div class="grid grid-cols-1 gap-10 xl:grid-cols-[0.7fr_1.3fr] xl:gap-16">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">The shelf</p>
        <h2 class="mt-3 max-w-lg font-serif text-4xl font-semibold leading-tight tracking-tight">
          A library that works backwards from your questions.
        </h2>
        <p class="mt-4 max-w-lg leading-relaxed text-soft">
          Each book page extracts the useful machinery: concepts, stories, frameworks, failure modes,
          and when to apply them. That lets each answer point back to real source material instead of
          stopping at surface-level advice.
        </p>
        <p class="mt-6">
          <a href="/books/" class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
            See all books
          </a>
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {featuredBooks.map((book) => <BookRow book={book} />)}
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-ink text-paper">
    <div class="mx-auto grid max-w-[1440px] grid-cols-1 gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:px-20 xl:px-[120px]">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-paper/55 font-sans">Internet question engine</p>
        <h2 class="mt-3 max-w-lg font-serif text-4xl font-semibold leading-tight tracking-tight">
          The questions people click become better book-grounded answers.
        </h2>
        <p class="mt-4 max-w-lg leading-relaxed text-paper/70">
          CrowdListen can reveal what people are asking, saving, debating, and getting stuck on across
          the internet. Answer with Books uses that demand signal to choose what to synthesize next,
          while books supply the deeper judgment.
        </p>
      </div>
      <div class="grid gap-3">
        {[
          ['Top of mind', 'Am I validating this idea or just collecting compliments?'],
          ['Source lenses', 'The Mom Test + Thinking, Fast and Slow'],
          ['Digestible answer', 'Past behavior beats polite feedback; base rates beat founder optimism.'],
        ].map(([label, text]) => (
          <div class="rounded-md border border-white/10 bg-white/[0.06] p-5">
            <p class="text-xs uppercase tracking-[0.18em] text-paper/45 font-sans">{label}</p>
            <p class="mt-2 font-serif text-2xl font-semibold leading-tight">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-5 py-16 sm:px-8 lg:px-20 xl:px-[120px]">
    <div class="mb-7 flex items-end justify-between gap-5">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Featured answers</p>
        <h2 class="mt-3 font-serif text-4xl font-semibold tracking-tight">Answers from the shelf</h2>
      </div>
      <a href="/answers/" class="hidden text-sm text-accent underline underline-offset-4 decoration-1 sm:inline">
        All answers
      </a>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {featuredAnswers.map((answer) => <AnswerRow answer={answer} bookTitles={bookTitles} />)}
    </div>
  </section>

  <section class="mx-auto max-w-[1440px] px-5 pb-16 sm:px-8 lg:px-20 xl:px-[120px]">
    <div class="grid grid-cols-1 gap-8 rounded-md border border-line bg-wash p-6 sm:grid-cols-[1fr_auto] sm:items-center sm:p-8">
      <div>
        <h2 class="font-serif text-3xl font-semibold tracking-tight">Build a shelf around what you care about</h2>
        <p class="mt-3 max-w-2xl leading-relaxed text-soft">
          Save books, follow answers, and turn your recurring questions into a living library of ideas
          you can call on.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/signup/"
          class="bg-ink text-paper px-5 py-2.5 rounded-sm hover:bg-accent transition-colors text-[0.95rem]"
        >
          Create account
        </a>
        <a
          href="/login/"
          class="border border-line px-5 py-2.5 rounded-sm text-[0.95rem] text-soft hover:border-accent hover:text-accent"
        >
          Log in
        </a>
      </div>
    </div>
  </section>
</Base>
