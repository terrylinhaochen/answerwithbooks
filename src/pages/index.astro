---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BookCover from '../components/BookCover.astro';
import BookRow from '../components/BookRow.astro';
import AnswerRow from '../components/AnswerRow.astro';
import ActivityPanel from '../components/ActivityPanel.astro';
import FaqList from '../components/FaqList.astro';
import { faqJsonLd } from '../lib/seo';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const answers = (await getCollection('answers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredBooks = books.filter((b) => b.data.featured);
const featuredAnswers = answers.filter((a) => a.data.featured);
const shelfBooks = [
  ...featuredBooks,
  ...books.filter((book) => !featuredBooks.some((featuredBook) => featuredBook.id === book.id)),
].slice(0, 8);
const shelfAnswers = [
  ...featuredAnswers,
  ...answers.filter((answer) => !featuredAnswers.some((featuredAnswer) => featuredAnswer.id === answer.id)),
].slice(0, 6);
const bookTitles = new Map(books.map((b) => [b.id, b.data.title]));
const bookById = new Map(books.map((b) => [b.id, b]));
const carouselIds = [
  'how-to-fix-user-interviews-that-are-not-teaching-you-anything',
  'how-to-tell-whether-to-pivot-or-keep-going',
  'how-to-make-a-plan-that-survives-contact-with-reality',
];
const carouselCopy = new Map([
  [
    'how-to-fix-user-interviews-that-are-not-teaching-you-anything',
    {
      title: 'Ask about recent behavior.',
      body: 'The Mom Test turns vague praise into evidence you can act on.',
    },
  ],
  [
    'how-to-tell-whether-to-pivot-or-keep-going',
    {
      title: 'Separate puzzles from anomalies.',
      body: 'Kuhn helps you tell normal iteration from evidence that the whole frame is wrong.',
    },
  ],
  [
    'how-to-make-a-plan-that-survives-contact-with-reality',
    {
      title: 'Keep local facts in the plan.',
      body: 'Seeing Like a State shows why plans fail when messy ground truth gets deleted.',
    },
  ],
]);
const carouselItems = carouselIds
  .map((id) => answers.find((answer) => answer.id === id))
  .filter(Boolean)
  .map((answer) => ({
    answer,
    books: answer.data.books.map((slug) => bookById.get(slug)).filter(Boolean).slice(0, 3),
    copy: carouselCopy.get(answer.id) ?? {
      title: answer.data.question,
      body: answer.data.description,
    },
  }));
const installCommand = 'npx answer-with-books install --skill --api';
const siteDescription = 'The best way to learn from books using AI.';
const homeFaqs = [
  {
    question: 'How does Answer with Books work?',
    answer:
      'You start with what is on your mind. Answer with Books turns that into sharper questions, then finds book-backed insights that match the situation.',
  },
  {
    question: 'What makes this different from normal book summaries?',
    answer:
      'The unit is not a chapter summary. Each answer starts from a real problem, then uses one to three books as lenses for judgment, tradeoffs, and next moves.',
  },
  {
    question: 'What is included in the public shelf?',
    answer:
      'The public shelf includes source book pages, book-grounded answers, search, categories, and examples of how books can be applied to work and life decisions.',
  },
  {
    question: 'What would a paid subscription unlock?',
    answer:
      'The paid version should unlock a fuller catalog, personal saved books, custom books, private shelves, community demand signals, and agent/API access.',
  },
  {
    question: 'Can I use this with my AI tools?',
    answer:
      'Yes. The agent skill is the direction: give your chat AI a book-grounded shelf it can call while you are working through real questions.',
  },
];

const jsonLd = [
  {
    '@type': 'WebSite',
    '@id': 'https://answerwithbooks.com/#website',
    name: 'Answer with Books',
    alternateName: 'answerwithbooks.com',
    url: 'https://answerwithbooks.com/',
    description: siteDescription,
    author: { '@id': 'https://answerwithbooks.com/#person' },
    publisher: { '@id': 'https://answerwithbooks.com/#person' },
    inLanguage: 'en',
  },
  {
    '@type': 'Person',
    '@id': 'https://answerwithbooks.com/#person',
    name: 'Terry Chen',
    url: 'https://terrylinhaochen.github.io',
    sameAs: ['https://terrylinhaochen.github.io'],
  },
  {
    '@type': 'WebPage',
    '@id': 'https://answerwithbooks.com/#webpage',
    url: 'https://answerwithbooks.com/',
    name: 'The Best Way to Learn From Books Using AI',
    description: siteDescription,
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Featured book-grounded answers',
      itemListElement: shelfAnswers.map((answer, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: answer.data.question,
        url: `https://answerwithbooks.com/answers/${answer.id}/`,
      })),
    },
  },
  {
    '@type': 'SiteNavigationElement',
    name: ['Books', 'Answers', 'Get started'],
    url: [
      'https://answerwithbooks.com/books/',
      'https://answerwithbooks.com/answers/',
      'https://answerwithbooks.com/onboarding/start/',
    ],
  },
  {
    ...faqJsonLd('https://answerwithbooks.com/', homeFaqs),
  },
];
---

<Base
  title="The Best Way to Learn From Books Using AI"
  description={siteDescription}
  path="/"
  jsonLd={jsonLd}
>
  <section class="awb-section pb-14 pt-12 sm:pt-16 lg:pb-20 lg:pt-20">
    <div class="grid min-w-0 grid-cols-1 items-stretch gap-10 xl:grid-cols-[0.95fr_1.05fr] xl:gap-16">
      <div class="flex min-w-0 flex-col justify-center">
        <p class="max-w-[20rem] font-sans text-xs font-semibold uppercase leading-relaxed tracking-[0.08em] text-faint sm:max-w-none">
          Learn from books with AI
        </p>
        <h1 class="mt-5 max-w-[13ch] break-words font-serif text-[2.85rem] leading-[1.03] sm:max-w-3xl sm:text-6xl xl:text-[4.75rem]">
          The best way to learn from books using AI.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-soft">
          Start with what you are trying to solve. Get the question behind it, the book lens that fits, and a useful next move.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4 text-[0.95rem]">
          <a
            href="/onboarding/start/"
            class="awb-pill awb-pill-primary transition-colors"
          >
            Get started
          </a>
          <a href="/answers/" class="awb-pill awb-pill-outline transition-colors">
            Explore answers
          </a>
        </div>
      </div>

      <div class="awb-panel flex min-w-0 flex-col justify-center p-5">
        <div class="min-w-0" data-insight-carousel>
          {carouselItems.map((item, slideIndex) => (
            <article data-carousel-slide={slideIndex} class={slideIndex === 0 ? '' : 'hidden'}>
              <div class="flex items-center justify-between gap-3">
                <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Insight carousel</p>
                <p class="font-sans text-xs text-faint">{slideIndex + 1} / {carouselItems.length}</p>
              </div>

              <div class="mt-5 rounded-2xl border border-line bg-wash p-5">
                <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Demand signal</p>
                <h2 class="mt-3 font-serif text-2xl leading-tight sm:text-[1.85rem]">
                  {item.answer.data.question}
                </h2>
              </div>

              <div class="mt-5 grid min-w-0 grid-cols-1 gap-5 lg:grid-cols-[0.95fr_1.05fr] lg:items-stretch">
                <div class="flex min-w-0 flex-col justify-between rounded-2xl border border-line bg-card p-4">
                  <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Books</p>
                  <div class="mt-4 flex items-end justify-center gap-2">
                    {item.books.map((book, index) => (
                      <BookCover
                        book={book}
                        size={index === 1 ? 'md' : 'sm'}
                        class={index === 1 ? 'relative z-10' : 'relative'}
                      />
                    ))}
                  </div>
                </div>

                <div class="rounded-2xl border border-line bg-ink p-4 text-white">
                  <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-white/55">Useful takeaway</p>
                  <p class="mt-4 font-serif text-2xl leading-tight">
                    {item.copy.title}
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-white/65">
                    {item.copy.body}
                  </p>
                </div>
              </div>

              <div class="mt-5 flex items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                  {carouselItems.map((_, dotIndex) => (
                    <button
                      type="button"
                      class={`awb-dot ${dotIndex === slideIndex ? 'awb-dot--active' : ''}`}
                      aria-label={`Show insight ${dotIndex + 1}`}
                      data-carousel-dot={dotIndex}
                    ></button>
                  ))}
                </div>
                <a href={`/answers/${item.answer.id}/`} class="inline-flex min-h-8 items-center font-sans text-sm font-medium text-ink underline underline-offset-4 decoration-1 hover:text-soft">
                  Open insight
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="awb-section pb-16">
    <div class="awb-panel overflow-hidden px-5 py-10 sm:px-7 lg:px-10 lg:py-12">
      <div class="grid gap-7 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Question-first reading</p>
          <h2 class="mt-3 max-w-2xl font-serif text-4xl leading-tight lg:text-[2.85rem]">
            The shelf starts working when it knows what you are stuck on.
          </h2>
        </div>
        <div>
          <p class="max-w-2xl text-lg leading-relaxed text-soft">
            Most reading tools start with summaries. Answer with Books starts with the situation on your mind, then points you toward the sharper question and the book lens that fits.
          </p>
          <a
            href="/onboarding/start/"
            class="awb-pill awb-pill-primary mt-6 transition-colors"
          >
            Start personalization
          </a>
        </div>
      </div>
      <div class="mt-10 grid gap-4 border-t border-line pt-8 lg:grid-cols-3">
        {[
          ['Start with the situation', 'Name what you are trying to solve instead of searching by book title.'],
          ['Find the better question', 'Turn vague top-of-mind thoughts into something you can actually work through.'],
          ['Open the right lens', 'Pull the framework, story, or next move from the book that fits the moment.'],
        ].map(([title, text], index) => (
          <article class="rounded-2xl border border-line bg-wash/70 p-5">
            <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">0{index + 1}</p>
            <h3 class="mt-3 font-serif text-2xl leading-tight">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-soft">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script>
    const carousel = document.querySelector<HTMLElement>('[data-insight-carousel]');
    const slides = Array.from(carousel?.querySelectorAll<HTMLElement>('[data-carousel-slide]') ?? []);
    let activeSlide = 0;
    let slideTimer: number | undefined;

    const showSlide = (index: number) => {
      if (slides.length === 0) return;
      activeSlide = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        slide.hidden = slideIndex !== activeSlide;
        slide.classList.toggle('hidden', slideIndex !== activeSlide);
      });
    };

    const scheduleSlide = () => {
      window.clearInterval(slideTimer);
      slideTimer = window.setInterval(() => showSlide(activeSlide + 1), 5200);
    };

    carousel?.addEventListener('click', (event) => {
      const dot = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-carousel-dot]');
      if (!dot) return;
      showSlide(Number(dot.dataset.carouselDot ?? 0));
      scheduleSlide();
    });

    showSlide(0);
    scheduleSlide();
  </script>

  <section id="install" class="awb-section">
    <div class="awb-panel grid grid-cols-1 overflow-hidden lg:grid-cols-[0.82fr_1.18fr]">
      <div class="border-b border-line px-5 py-8 sm:px-7 lg:border-b-0 lg:border-r lg:py-9">
        <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Agent skill</p>
        <h2 class="mt-3 max-w-md font-serif text-3xl leading-tight sm:text-4xl">
          Install the shelf as a skill.
        </h2>
        <p class="mt-3 max-w-lg leading-relaxed text-soft">
          Give your chat AI books it can call while you work.
        </p>
      </div>
      <div class="px-5 py-8 sm:px-7 lg:py-9">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-faint">Install</p>
            <p class="mt-2 text-sm leading-relaxed text-soft">
              Add the book layer to your agent setup.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 text-sm">
            <a href="/signup/" class="awb-pill awb-pill-primary min-h-0 px-4 py-2 transition-colors">Create account</a>
            <a href="/books/" class="awb-pill awb-pill-outline min-h-0 px-4 py-2 transition-colors">
              Browse books
            </a>
          </div>
        </div>
        <div class="mt-5 rounded-2xl border border-ink/10 bg-ink p-2 shadow-sm">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <pre class="min-w-0 flex-1 overflow-x-auto px-3 py-3 font-sans text-[0.88rem] leading-relaxed text-white"><code class="whitespace-nowrap"><span class="select-none text-white/45">$ </span><span data-install-command>{installCommand}</span></code></pre>
            <button
              type="button"
              class="min-h-11 rounded-xl border border-white/15 bg-white/10 px-4 font-sans text-xs font-semibold uppercase tracking-[0.12em] text-white transition-colors hover:bg-white hover:text-ink"
              data-copy-install
              aria-describedby="install-copy-status"
            >
              Copy
            </button>
          </div>
          <p id="install-copy-status" class="sr-only" aria-live="polite" data-copy-install-status></p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const copyInstallButton = document.querySelector<HTMLButtonElement>('[data-copy-install]');
    const installCommandNode = document.querySelector<HTMLElement>('[data-install-command]');
    const copyInstallStatus = document.querySelector<HTMLElement>('[data-copy-install-status]');

    const copyText = async (value: string) => {
      if (navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(value);
          return;
        } catch {
          // Continue to the textarea fallback for embedded browsers.
        }
      }
      const field = document.createElement('textarea');
      field.value = value;
      field.setAttribute('readonly', '');
      field.style.position = 'fixed';
      field.style.opacity = '0';
      document.body.appendChild(field);
      field.select();
      const copied = document.execCommand('copy');
      field.remove();
      if (!copied) throw new Error('Copy command failed');
    };

    copyInstallButton?.addEventListener('click', async () => {
      const command = installCommandNode?.textContent?.trim();
      if (!command) return;
      const original = copyInstallButton.textContent;
      try {
        await copyText(command);
        copyInstallButton.textContent = 'Copied';
        if (copyInstallStatus) copyInstallStatus.textContent = 'Install command copied.';
      } catch {
        copyInstallButton.textContent = 'Failed';
        if (copyInstallStatus) copyInstallStatus.textContent = 'Install command could not be copied.';
      } finally {
        window.setTimeout(() => {
          copyInstallButton.textContent = original ?? 'Copy';
        }, 1800);
      }
    });
  </script>

  <section class="awb-section py-16">
    <div class="mb-7 flex items-end justify-between gap-5">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-faint font-sans">Featured books</p>
        <h2 class="mt-3 font-serif text-4xl">Source books</h2>
      </div>
      <a href="/books/" class="hidden font-sans text-sm font-medium text-ink underline underline-offset-4 decoration-1 hover:text-soft sm:inline">
        All books
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {shelfBooks.map((book) => <BookRow book={book} compact />)}
    </div>
  </section>

  <section class="awb-section">
    <div class="awb-panel grid grid-cols-1 gap-10 px-5 py-16 sm:px-6 lg:grid-cols-[0.88fr_1.12fr] lg:px-10">
      <div class="flex flex-col justify-center">
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-faint font-sans">Profile</p>
        <h2 class="mt-3 max-w-lg font-serif text-4xl leading-tight">
          Track what keeps showing up.
        </h2>
        <p class="mt-4 max-w-lg leading-relaxed text-soft">
          See the books, answers, and patterns you return to.
        </p>
      </div>
      <ActivityPanel
        eyebrow="Profile tracker"
        title="A visible trail of useful insights."
        description="Open insights, save books, and build a stash of book-backed answers for the situations that keep coming up."
        compact
        showDetails={false}
        class="bg-card text-ink"
      />
    </div>
  </section>

  <section class="awb-section py-16">
    <div class="mb-7 flex items-end justify-between gap-5">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.08em] text-faint font-sans">Featured answers</p>
        <h2 class="mt-3 font-serif text-4xl">Answers from the shelf</h2>
      </div>
      <a href="/answers/" class="hidden font-sans text-sm font-medium text-ink underline underline-offset-4 decoration-1 hover:text-soft sm:inline">
        All answers
      </a>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {shelfAnswers.map((answer) => <AnswerRow answer={answer} bookTitles={bookTitles} compact />)}
    </div>
  </section>

  <FaqList items={homeFaqs} eyebrow="FAQ" title="Got questions? We have answers." width="wide" />
</Base>
