---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BookRow from '../components/BookRow.astro';
import AnswerRow from '../components/AnswerRow.astro';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const answers = (await getCollection('answers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredBooks = books.filter((b) => b.data.featured).slice(0, 3);
const featuredAnswers = answers.filter((a) => a.data.featured).slice(0, 3);
const bookTitles = new Map(books.map((b) => [b.id, b.data.title]));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Answer with Books',
  url: 'https://answerwithbooks.com/',
  description:
    'Every book becomes a set of usable ideas; real questions get answered with them.',
  author: { '@type': 'Person', name: 'Terry Chen', url: 'https://terrylinhaochen.github.io' },
};
---

<Base
  title="Answer with Books — every book you've read, ready to answer"
  description="Books distilled into answers. Mental models and frameworks from great books, applied to real questions about startups, decisions, and systems."
  path="/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-3xl px-5 pt-20 pb-16 sm:pt-28">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.12]">
      Every book you've read,<br />
      <span class="italic font-medium text-accent">ready to answer.</span>
    </h1>
    <p class="mt-6 text-lg text-soft leading-relaxed max-w-xl">
      Most books decay into a vague feeling of having read them. This site is the alternative: each
      book I read becomes a distilled page of mental models and frameworks — and real questions get
      answered by putting those books to work.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-5 text-[0.95rem]">
      <a
        href="/answers/"
        class="bg-ink text-paper px-5 py-2.5 rounded-sm hover:bg-accent transition-colors"
      >
        Browse the answers
      </a>
      <a href="/books/" class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
        Or start with the books
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12 border-t border-line">
    <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans">How it works</h2>
    <div class="mt-6 grid gap-8 sm:grid-cols-3">
      <div>
        <p class="font-serif text-lg font-semibold">1. Read</p>
        <p class="mt-2 text-soft text-[0.95rem] leading-relaxed">
          A book earns a page here only after a real reading — no summaries of summaries.
        </p>
      </div>
      <div>
        <p class="font-serif text-lg font-semibold">2. Distill</p>
        <p class="mt-2 text-soft text-[0.95rem] leading-relaxed">
          Each book is reduced to its load-bearing ideas: mental models, frameworks, and when to
          reach for them.
        </p>
      </div>
      <div>
        <p class="font-serif text-lg font-semibold">3. Answer</p>
        <p class="mt-2 text-soft text-[0.95rem] leading-relaxed">
          Real questions — about startups, decisions, systems — answered by combining books with
          lived experience.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12 border-t border-line">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Featured answers</h2>
      <a href="/answers/" class="text-sm text-accent underline underline-offset-4 decoration-1">All answers</a>
    </div>
    <div class="mt-2">
      {featuredAnswers.map((answer) => <AnswerRow answer={answer} bookTitles={bookTitles} />)}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12 border-t border-line">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans">From the shelf</h2>
      <a href="/books/" class="text-sm text-accent underline underline-offset-4 decoration-1">All books</a>
    </div>
    <div class="mt-2">
      {featuredBooks.map((book) => <BookRow book={book} />)}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-14 border-t border-line">
    <h2 class="font-serif text-2xl font-semibold tracking-tight">Keep a shelf of your own</h2>
    <p class="mt-3 text-soft leading-relaxed max-w-xl">
      Create a free account to save books and answers for later.
    </p>
    <p class="mt-5">
      <a
        href="/signup/"
        class="bg-ink text-paper px-5 py-2.5 rounded-sm hover:bg-accent transition-colors text-[0.95rem]"
      >
        Create an account
      </a>
      <a href="/login/" class="ml-4 text-sm text-accent underline underline-offset-4 decoration-1">
        Log in
      </a>
    </p>
  </section>
</Base>
