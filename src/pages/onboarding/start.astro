---
import Base from '../../layouts/Base.astro';

const focusOptions = [
  { value: 'business', label: 'Business', detail: 'Strategy, customers, growth, and market decisions.' },
  { value: 'technology', label: 'Technology', detail: 'Systems, engineering judgment, AI, and product quality.' },
  { value: 'productivity', label: 'Productivity', detail: 'Focus, execution, habits, and attention.' },
  { value: 'career', label: 'Career', detail: 'Skill growth, management, leverage, and next steps.' },
  { value: 'decisions', label: 'Decisions', detail: 'Uncertainty, intuition, tradeoffs, and judgment.' },
  { value: 'relationships', label: 'Relationships', detail: 'Feedback, communication, conflict, and trust.' },
];

const shelfOptions = [
  { value: 'public', label: 'Start with the public shelf', detail: 'Use the books already distilled on Answer with Books.' },
  { value: 'owned', label: 'Use books I already care about', detail: 'Turn your own reading list into callable source material.' },
  { value: 'unknowns', label: 'Surface unknown unknowns', detail: 'Recommend adjacent books and insights from your trail.' },
];
---

<Base
  title="Get started"
  description="Personalize your Answer with Books shelf around the questions, books, and insights you want to understand."
  path="/onboarding/start/"
  robots="noindex, follow"
>
  <section class="mx-auto max-w-6xl px-5 py-14 sm:py-16">
    <div class="border-y border-line bg-wash/55">
      <div class="grid gap-7 border-b border-line px-5 py-8 sm:px-7 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Get started</p>
          <h1 class="mt-3 max-w-3xl font-serif text-5xl font-semibold leading-[1.04] tracking-tight sm:text-6xl">
            Tell the shelf what you are trying to solve.
          </h1>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-soft">
            We will use this to shape your question profile, recommend source books, and make the next insight more relevant.
          </p>
        </div>
        <a href="/answers/" class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
          Skip and explore insights
        </a>
      </div>

      <form data-onboarding-form class="grid gap-0 lg:grid-cols-[1fr_21rem]">
        <div class="px-5 py-7 sm:px-7">
          <div class="mb-7 grid gap-2 sm:grid-cols-3" aria-label="Onboarding progress">
            <button
              type="button"
              data-step-jump="0"
              class="border border-line bg-paper px-4 py-3 text-left transition-colors"
            >
              <span class="block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-faint">1. Focus</span>
              <span class="mt-1 block font-serif text-lg font-semibold leading-tight">What matters now</span>
            </button>
            <button
              type="button"
              data-step-jump="1"
              class="border border-line bg-paper px-4 py-3 text-left transition-colors"
            >
              <span class="block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-faint">2. Shelf</span>
              <span class="mt-1 block font-serif text-lg font-semibold leading-tight">Where to start</span>
            </button>
            <button
              type="button"
              data-step-jump="2"
              class="border border-line bg-paper px-4 py-3 text-left transition-colors"
            >
              <span class="block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-faint">3. Use case</span>
              <span class="mt-1 block font-serif text-lg font-semibold leading-tight">What to solve</span>
            </button>
          </div>

          <section data-onboarding-step="0">
            <fieldset>
              <legend class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Choose your focus</legend>
              <h2 class="mt-3 max-w-2xl font-serif text-4xl font-semibold leading-tight">
                Pick the areas where better book-backed judgment would actually help.
              </h2>
              <p class="mt-3 max-w-2xl text-soft">
                Choose one or more. This gives the content engine a first signal for which questions, examples, and books to surface.
              </p>
              <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
              {
                focusOptions.map((option) => (
                  <label class="group flex min-h-[8rem] cursor-pointer flex-col justify-between border border-line bg-paper p-4 transition-colors hover:border-accent">
                    <input class="peer sr-only" type="checkbox" name="focus" value={option.value} />
                    <span class="font-serif text-2xl font-semibold leading-tight text-ink group-has-[:checked]:text-accent">
                      {option.label}
                    </span>
                    <span class="mt-3 text-sm leading-relaxed text-soft">{option.detail}</span>
                  </label>
                ))
              }
              </div>
            </fieldset>
          </section>

          <section data-onboarding-step="1" class="hidden">
            <fieldset>
              <legend class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Start the shelf</legend>
              <h2 class="mt-3 max-w-2xl font-serif text-4xl font-semibold leading-tight">
                Tell us what source material should drive the first recommendations.
              </h2>
              <p class="mt-3 max-w-2xl text-soft">
                The product should feel useful before your full library exists, then get sharper as your own books and behavior come in.
              </p>
              <div class="mt-5 grid gap-3">
              {
                shelfOptions.map((option) => (
                  <label class="group flex cursor-pointer items-start gap-3 border border-line bg-paper p-5 transition-colors hover:border-accent">
                    <input class="mt-1 accent-accent" type="radio" name="shelf" value={option.value} checked={option.value === 'public'} />
                    <span>
                      <span class="block font-serif text-2xl font-semibold leading-tight group-has-[:checked]:text-accent">
                        {option.label}
                      </span>
                      <span class="mt-1 block text-sm leading-relaxed text-soft">{option.detail}</span>
                    </span>
                  </label>
                ))
              }
              </div>
            </fieldset>
          </section>

          <section data-onboarding-step="2" class="hidden">
            <label>
              <span class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Current top of mind</span>
              <span class="mt-3 block max-w-2xl font-serif text-4xl font-semibold leading-tight">
                What are you trying to understand, decide, or get unstuck on?
              </span>
              <textarea
                name="goal"
                rows="5"
                class="mt-5 w-full resize-y border border-line bg-paper px-4 py-3 font-serif text-lg leading-relaxed text-ink outline-none transition-colors placeholder:text-faint focus:border-accent"
                placeholder="Example: I want better customer interviews, sharper positioning, and a reading trail that helps me make product decisions."
              ></textarea>
            </label>

            <div id="chatgpt-connection" class="mt-5 border border-line bg-paper p-5">
              <div class="grid gap-4 sm:grid-cols-[1fr_auto] sm:items-start">
                <div>
                  <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">ChatGPT</p>
                  <h3 class="mt-2 font-serif text-2xl font-semibold leading-tight">Use this shelf inside ChatGPT.</h3>
                  <p class="mt-2 text-sm leading-relaxed text-soft">
                    The right version is a ChatGPT app or action that calls your Answer with Books profile. It should not import private ChatGPT history.
                  </p>
                </div>
                <button
                  type="button"
                  data-chatgpt-connect
                  aria-pressed="false"
                  class="border border-ink px-4 py-2 text-sm text-ink transition-colors hover:border-accent hover:text-accent"
                >
                  Link later
                </button>
              </div>
              <input type="hidden" name="chatgptIntent" value="none" />
              <label class="mt-4 block">
                <span class="font-sans text-xs uppercase tracking-[0.16em] text-faint">How you would use it</span>
                <input
                  name="chatgptUseCase"
                  class="mt-2 w-full border border-line bg-wash/60 px-3 py-2 text-sm text-ink outline-none transition-colors placeholder:text-faint focus:border-accent"
                  placeholder="Example: call my shelf while planning content, product decisions, or customer research."
                />
              </label>
            </div>
          </section>

          <div class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-5">
            <button
              type="button"
              data-step-back
              class="border border-line px-5 py-2.5 text-[0.95rem] text-soft transition-colors hover:border-accent hover:text-accent"
            >
              Back
            </button>
            <button
              type="button"
              data-step-next
              class="bg-ink px-5 py-2.5 text-paper transition-colors hover:bg-accent"
            >
              Continue
            </button>
            <button
              type="submit"
              data-step-submit
              class="hidden bg-ink px-5 py-2.5 text-paper transition-colors hover:bg-accent"
            >
              Save and create profile
            </button>
          </div>
        </div>

        <aside class="border-t border-line bg-paper px-5 py-7 sm:px-7 lg:border-l lg:border-t-0">
          <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Setup</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold leading-tight" data-step-title>
            Start with demand.
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-soft">
            Your choices are saved in this browser as you move through the flow. After the final step, sign in or create an account to sync them.
          </p>
          <div class="mt-6 grid gap-3 text-sm text-soft">
            <div class="border-t border-line pt-3">
              <span class="font-sans text-xs uppercase tracking-[0.16em] text-faint">Now</span>
              <p class="mt-1" data-step-now>Choose the categories that match what you are trying to solve.</p>
            </div>
            <div class="border-t border-line pt-3">
              <span class="font-sans text-xs uppercase tracking-[0.16em] text-faint">Next</span>
              <p class="mt-1" data-step-next-copy>Pick the shelf strategy.</p>
            </div>
            <div class="border-t border-line pt-3">
              <span class="font-sans text-xs uppercase tracking-[0.16em] text-faint">ChatGPT note</span>
              <p class="mt-1">
                Account linking should work through an Answer with Books ChatGPT app or action, not by scraping ChatGPT history.
              </p>
            </div>
          </div>
          <p data-onboarding-message role="status" class="mt-7 hidden text-sm leading-relaxed text-soft"></p>
        </aside>
      </form>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';
    import {
      readOnboardingProfile,
      writeOnboardingProfile,
      persistOnboardingProfile,
      type OnboardingProfile,
    } from '../../lib/onboarding';

    const form = document.querySelector<HTMLFormElement>('[data-onboarding-form]');
    const message = document.querySelector<HTMLElement>('[data-onboarding-message]');
    const steps = [...document.querySelectorAll<HTMLElement>('[data-onboarding-step]')];
    const jumps = [...document.querySelectorAll<HTMLButtonElement>('[data-step-jump]')];
    const back = document.querySelector<HTMLButtonElement>('[data-step-back]');
    const next = document.querySelector<HTMLButtonElement>('[data-step-next]');
    const submit = document.querySelector<HTMLButtonElement>('[data-step-submit]');
    const stepTitle = document.querySelector<HTMLElement>('[data-step-title]');
    const stepNow = document.querySelector<HTMLElement>('[data-step-now]');
    const stepNextCopy = document.querySelector<HTMLElement>('[data-step-next-copy]');
    const chatgptButton = document.querySelector<HTMLButtonElement>('[data-chatgpt-connect]');
    const chatgptIntent = form?.querySelector<HTMLInputElement>('input[name="chatgptIntent"]');
    const existing = readOnboardingProfile();
    const STEP_KEY = 'awb:onboarding:step';
    const stepCopy = [
      {
        title: 'Start with demand.',
        now: 'Choose the categories that match what you are trying to solve.',
        next: 'Pick the shelf strategy.',
      },
      {
        title: 'Choose the source layer.',
        now: 'Decide whether to start from the public shelf, your own books, or adjacent unknowns.',
        next: 'Name the actual use case.',
      },
      {
        title: 'Make it actionable.',
        now: 'Write the situation and choose whether ChatGPT should become a future surface.',
        next: 'Create an account to sync the profile.',
      },
    ];
    let currentStep = Math.min(Math.max(Number(localStorage.getItem(STEP_KEY) ?? '0') || 0, 0), steps.length - 1);

    if (form && existing) {
      for (const value of existing.focus) {
        const input = form.querySelector<HTMLInputElement>(`input[name="focus"][value="${value}"]`);
        if (input) input.checked = true;
      }
      const shelf = form.querySelector<HTMLInputElement>(`input[name="shelf"][value="${existing.shelf}"]`);
      if (shelf) shelf.checked = true;
      const goal = form.querySelector<HTMLTextAreaElement>('textarea[name="goal"]');
      if (goal) goal.value = existing.goal;
      if (existing.chatgpt?.intent === 'connect' && chatgptIntent && chatgptButton) {
        chatgptIntent.value = 'connect';
        chatgptButton.textContent = 'ChatGPT marked';
        chatgptButton.setAttribute('aria-pressed', 'true');
        chatgptButton.classList.add('border-accent', 'text-accent');
      }
      const useCase = form.querySelector<HTMLInputElement>('input[name="chatgptUseCase"]');
      if (useCase) useCase.value = existing.chatgpt?.useCase ?? '';
    }

    const snapshotProfile = (pending = false) => {
      if (!form) return null;
      const data = new FormData(form);
      const now = new Date().toISOString();
      const profile: OnboardingProfile = {
        version: 1,
        focus: data.getAll('focus').map(String),
        shelf: String(data.get('shelf') || 'public'),
        goal: String(data.get('goal') || '').trim(),
        chatgpt: {
          intent: data.get('chatgptIntent') === 'connect' ? 'connect' : 'none',
          useCase: String(data.get('chatgptUseCase') || '').trim(),
        },
        createdAt: existing?.createdAt || now,
        updatedAt: now,
      };
      writeOnboardingProfile(profile, pending);
      return profile;
    };

    const showStep = (step: number) => {
      currentStep = Math.min(Math.max(step, 0), steps.length - 1);
      localStorage.setItem(STEP_KEY, String(currentStep));
      steps.forEach((node, index) => node.classList.toggle('hidden', index !== currentStep));
      jumps.forEach((button, index) => {
        button.classList.toggle('border-accent', index === currentStep);
        button.classList.toggle('bg-wash', index === currentStep);
        button.setAttribute('aria-current', index === currentStep ? 'step' : 'false');
      });
      if (back) back.classList.toggle('invisible', currentStep === 0);
      if (next) next.classList.toggle('hidden', currentStep === steps.length - 1);
      if (submit) submit.classList.toggle('hidden', currentStep !== steps.length - 1);
      const copy = stepCopy[currentStep];
      if (stepTitle) stepTitle.textContent = copy.title;
      if (stepNow) stepNow.textContent = copy.now;
      if (stepNextCopy) stepNextCopy.textContent = copy.next;
      if (message) message.classList.add('hidden');
    };

    jumps.forEach((button) => {
      button.addEventListener('click', () => {
        snapshotProfile(false);
        showStep(Number(button.dataset.stepJump || '0'));
      });
    });

    back?.addEventListener('click', () => {
      snapshotProfile(false);
      showStep(currentStep - 1);
    });

    next?.addEventListener('click', () => {
      snapshotProfile(false);
      showStep(currentStep + 1);
    });

    chatgptButton?.addEventListener('click', () => {
      if (!chatgptIntent) return;
      const nextValue = chatgptIntent.value === 'connect' ? 'none' : 'connect';
      chatgptIntent.value = nextValue;
      chatgptButton.textContent = nextValue === 'connect' ? 'ChatGPT marked' : 'Link later';
      chatgptButton.setAttribute('aria-pressed', nextValue === 'connect' ? 'true' : 'false');
      chatgptButton.classList.toggle('border-accent', nextValue === 'connect');
      chatgptButton.classList.toggle('text-accent', nextValue === 'connect');
      snapshotProfile(false);
    });

    form?.addEventListener('input', () => {
      snapshotProfile(false);
    });

    showStep(currentStep);

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      snapshotProfile(true);
      localStorage.removeItem(STEP_KEY);

      const { data: sessionData } = await supabase.auth.getSession();
      if (sessionData.session) {
        if (message) {
          message.textContent = 'Saving to your profile...';
          message.classList.remove('hidden');
        }
        await persistOnboardingProfile(supabase, sessionData.session);
        window.location.href = '/profile/?onboarded=1';
      } else {
        window.location.href = '/signup/?from=onboarding';
      }
    });
  </script>
</Base>
