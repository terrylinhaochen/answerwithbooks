---
import Base from '../../layouts/Base.astro';

const focusOptions = [
  { value: 'business', label: 'Business' },
  { value: 'technology', label: 'Technology' },
  { value: 'productivity', label: 'Productivity' },
  { value: 'career', label: 'Career' },
  { value: 'decisions', label: 'Decisions' },
  { value: 'relationships', label: 'Relationships' },
];

const shelfOptions = [
  { value: 'public', label: 'Start with the public shelf', detail: 'Use the books already distilled on Answer with Books.' },
  { value: 'owned', label: 'Use books I already care about', detail: 'Turn your own reading list into callable source material.' },
  { value: 'unknowns', label: 'Surface unknown unknowns', detail: 'Recommend adjacent books and insights from your trail.' },
];
---

<Base
  title="Get started"
  description="Personalize your Answer with Books shelf around the questions, books, and insights you want to understand."
  path="/onboarding/start/"
  robots="noindex, follow"
>
  <section class="awb-section py-10 sm:py-14">
    <div class="awb-panel mx-auto max-w-3xl overflow-hidden">
      <div class="flex items-center justify-between gap-4 border-b border-line px-5 py-4 sm:px-7">
        <p class="font-serif text-xl">Get started</p>
        <a href="/answers/" class="text-sm text-soft underline decoration-line underline-offset-4 hover:text-ink">
          Skip for now
        </a>
      </div>

      <form data-onboarding-form class="px-5 py-7 sm:px-7 sm:py-9">
          <section data-onboarding-step="0">
            <fieldset>
              <legend class="awb-eyebrow">Step 1 of 3</legend>
              <h1 class="mt-3 font-serif text-4xl leading-tight sm:text-5xl">
                What do you want help with?
              </h1>
              <p class="mt-2 text-soft">Choose one or more.</p>
              <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {
                focusOptions.map((option) => (
                  <label class="awb-card-link group flex cursor-pointer items-center gap-3 p-4">
                    <input class="peer sr-only" type="checkbox" name="focus" value={option.value} />
                    <span aria-hidden="true" class="h-4 w-4 rounded-full border border-line group-has-[:checked]:border-accent group-has-[:checked]:bg-accent"></span>
                    <span class="font-serif text-xl leading-tight text-ink group-has-[:checked]:text-accent">
                      {option.label}
                    </span>
                  </label>
                ))
              }
              </div>
            </fieldset>
          </section>

          <section data-onboarding-step="1" class="hidden">
            <fieldset>
              <legend class="awb-eyebrow">Step 2 of 3</legend>
              <h2 class="mt-3 font-serif text-4xl leading-tight sm:text-5xl">
                Where should we start?
              </h2>
              <div class="mt-6 grid gap-3">
              {
                shelfOptions.map((option) => (
                  <label class="awb-card-link group flex cursor-pointer items-start gap-3 p-5">
                    <input class="mt-1 accent-accent" type="radio" name="shelf" value={option.value} checked={option.value === 'public'} />
                    <span>
                      <span class="block font-serif text-2xl leading-tight group-has-[:checked]:text-accent">
                        {option.label}
                      </span>
                      <span class="mt-1 block text-sm leading-relaxed text-soft">{option.detail}</span>
                    </span>
                  </label>
                ))
              }
              </div>
            </fieldset>
          </section>

          <section data-onboarding-step="2" class="hidden">
            <label>
              <span class="awb-eyebrow">Step 3 of 3</span>
              <span class="mt-3 block font-serif text-4xl leading-tight sm:text-5xl">
                What is top of mind?
              </span>
              <textarea
                name="goal"
                rows="4"
                class="awb-input mt-6 min-h-32 resize-y"
                placeholder="Describe what you are trying to understand, decide, or get unstuck on."
              ></textarea>
            </label>
          </section>

          <div class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-5">
            <button
              type="button"
              data-step-back
              class="awb-pill awb-pill-outline"
            >
              Back
            </button>
            <button
              type="button"
              data-step-next
              class="awb-pill awb-pill-primary"
            >
              Continue
            </button>
            <button
              type="submit"
              data-step-submit
              class="awb-pill awb-pill-primary hidden"
            >
              Finish
            </button>
          </div>
          <p data-onboarding-message role="status" class="mt-5 hidden text-sm leading-relaxed text-soft"></p>
      </form>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';
    import {
      readOnboardingProfile,
      writeOnboardingProfile,
      persistOnboardingProfile,
      type OnboardingProfile,
    } from '../../lib/onboarding';

    const form = document.querySelector<HTMLFormElement>('[data-onboarding-form]');
    const message = document.querySelector<HTMLElement>('[data-onboarding-message]');
    const steps = [...document.querySelectorAll<HTMLElement>('[data-onboarding-step]')];
    const back = document.querySelector<HTMLButtonElement>('[data-step-back]');
    const next = document.querySelector<HTMLButtonElement>('[data-step-next]');
    const submit = document.querySelector<HTMLButtonElement>('[data-step-submit]');
    const existing = readOnboardingProfile();
    const STEP_KEY = 'awb:onboarding:step';
    let currentStep = Math.min(Math.max(Number(localStorage.getItem(STEP_KEY) ?? '0') || 0, 0), steps.length - 1);

    if (form && existing) {
      for (const value of existing.focus) {
        const input = form.querySelector<HTMLInputElement>(`input[name="focus"][value="${value}"]`);
        if (input) input.checked = true;
      }
      const shelf = form.querySelector<HTMLInputElement>(`input[name="shelf"][value="${existing.shelf}"]`);
      if (shelf) shelf.checked = true;
      const goal = form.querySelector<HTMLTextAreaElement>('textarea[name="goal"]');
      if (goal) goal.value = existing.goal;
    }

    const snapshotProfile = (pending = false) => {
      if (!form) return null;
      const data = new FormData(form);
      const now = new Date().toISOString();
      const profile: OnboardingProfile = {
        version: 1,
        focus: data.getAll('focus').map(String),
        shelf: String(data.get('shelf') || 'public'),
        goal: String(data.get('goal') || '').trim(),
        chatgpt: existing?.chatgpt,
        createdAt: existing?.createdAt || now,
        updatedAt: now,
      };
      writeOnboardingProfile(profile, pending);
      return profile;
    };

    const showStep = (step: number) => {
      currentStep = Math.min(Math.max(step, 0), steps.length - 1);
      localStorage.setItem(STEP_KEY, String(currentStep));
      steps.forEach((node, index) => node.classList.toggle('hidden', index !== currentStep));
      if (back) back.classList.toggle('invisible', currentStep === 0);
      if (next) next.classList.toggle('hidden', currentStep === steps.length - 1);
      if (submit) submit.classList.toggle('hidden', currentStep !== steps.length - 1);
      if (message) message.classList.add('hidden');
    };

    back?.addEventListener('click', () => {
      snapshotProfile(false);
      showStep(currentStep - 1);
    });

    next?.addEventListener('click', () => {
      snapshotProfile(false);
      showStep(currentStep + 1);
    });

    form?.addEventListener('input', () => {
      snapshotProfile(false);
    });

    showStep(currentStep);

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      snapshotProfile(true);
      localStorage.removeItem(STEP_KEY);

      const { data: sessionData } = await supabase.auth.getSession();
      if (sessionData.session) {
        if (message) {
          message.textContent = 'Saving to your profile...';
          message.classList.remove('hidden');
        }
        await persistOnboardingProfile(supabase, sessionData.session);
        window.location.href = '/profile/?onboarded=1';
      } else {
        window.location.href = '/signup/?from=onboarding';
      }
    });
  </script>
</Base>
