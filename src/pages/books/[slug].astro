---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { topicsForTags } from '../../lib/topics';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { slug: book.id }, props: { book } }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const topics = topicsForTags(book.data.tags);

const answers = (await getCollection('answers'))
  .filter((a) => a.data.books.includes(book.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const url = `https://answerwithbooks.com/books/${book.id}/`;
const breadcrumbs = [
  { name: 'Answer with Books', url: 'https://answerwithbooks.com/' },
  { name: 'Books', url: 'https://answerwithbooks.com/books/' },
  { name: book.data.title, url },
];
const jsonLd = [
  {
    '@type': 'WebPage',
    '@id': `${url}#webpage`,
    url,
    name: `${book.data.title} by ${book.data.author}`,
    description: book.data.oneLiner,
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    mainEntityOfPage: { '@id': `${url}#webpage` },
    headline: `${book.data.title} by ${book.data.author}, distilled into usable ideas`,
    description: book.data.oneLiner,
    author: { '@type': 'Person', name: 'Terry Chen', url: 'https://terrylinhaochen.github.io' },
    publisher: { '@id': 'https://answerwithbooks.com/#person' },
    keywords: book.data.tags,
    about: { '@id': `${url}#book` },
    url,
  },
  {
    '@type': 'Book',
    '@id': `${url}#book`,
    name: book.data.title,
    author: { '@type': 'Person', name: book.data.author },
    datePublished: String(book.data.year),
    description: book.data.oneLiner,
    url,
    workExample: answers.map((answer) => ({
      '@type': 'CreativeWork',
      name: answer.data.question,
      url: `https://answerwithbooks.com/answers/${answer.id}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url,
    })),
  },
];
---

<Base
  title={`${book.data.title} by ${book.data.author} — distilled`}
  description={book.data.oneLiner}
  path={`/books/${book.id}/`}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-5 pt-16 pb-10">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-soft">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-accent">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/books/" class="hover:text-accent">Books</a></li>
      </ol>
    </nav>

    <header class="pb-8 border-b border-line">
      <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Book · distilled</p>
      <h1 class="mt-3 text-wrap break-words font-serif text-3xl font-semibold tracking-tight leading-tight sm:text-4xl">
        {book.data.title}
      </h1>
      <p class="mt-2 text-soft">
        {book.data.author}, {book.data.year}
      </p>
      <p class="mt-5 text-lg text-soft italic leading-relaxed max-w-prose">
        {book.data.oneLiner}
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-4">
        <button
          type="button"
          data-save-book={book.id}
          data-title={book.data.title}
          class="text-sm border border-line px-4 py-1.5 rounded-sm text-soft hover:border-accent hover:text-accent transition-colors cursor-pointer"
        >
          Save this book
        </button>
        {topics.map((topic) => (
          <a
            href={`/topics/${topic.slug}/`}
            class="text-xs uppercase tracking-wider text-faint font-sans hover:text-accent"
          >
            {topic.label}
          </a>
        ))}
      </div>
    </header>

    <section class="mt-4 py-4 px-5 bg-white/60 border border-line rounded-sm text-[0.95rem] text-soft leading-relaxed">
      <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans mb-2">
        Useful for
      </h2>
      <p>{book.data.readIf}</p>
    </section>

    <div class="prose-awb mt-8">
      <Content />
    </div>
  </article>

  {
    answers.length > 0 && (
      <aside class="mx-auto max-w-3xl px-5 pb-16">
        <div class="border-t border-line pt-8">
          <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans">
            Answers that draw on this book
          </h2>
          <ul class="mt-4 space-y-3">
            {answers.map((answer) => (
              <li>
                <a
                  href={`/answers/${answer.id}/`}
                  class="font-serif text-lg text-ink hover:text-accent underline underline-offset-4 decoration-line hover:decoration-accent"
                >
                  {answer.data.question}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )
  }

  <script>
    const KEY = 'awb:saved-books';
    const btn = document.querySelector<HTMLButtonElement>('[data-save-book]');
    if (btn) {
      const slug = btn.dataset.saveBook!;
      const read = (): string[] => {
        try {
          return JSON.parse(localStorage.getItem(KEY) ?? '[]');
        } catch {
          return [];
        }
      };
      const paint = () => {
        const saved = read().includes(slug);
        btn.textContent = saved ? 'Saved ✓ — remove' : 'Save this book';
      };
      btn.addEventListener('click', () => {
        const list = read();
        const next = list.includes(slug) ? list.filter((s) => s !== slug) : [...list, slug];
        localStorage.setItem(KEY, JSON.stringify(next));
        paint();
      });
      paint();
    }
  </script>
</Base>
