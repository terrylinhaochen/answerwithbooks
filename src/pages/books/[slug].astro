---
import { getCollection, render } from 'astro:content';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../../layouts/Base.astro';
import AnswerRow from '../../components/AnswerRow.astro';
import BookCover from '../../components/BookCover.astro';
import BookDigestPersonalizer from '../../components/BookDigestPersonalizer.astro';
import ContentFeedback from '../../components/ContentFeedback.astro';
import FaqList from '../../components/FaqList.astro';
import { topicsForTags } from '../../lib/topics';
import { compactDescription, compactList, faqJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { slug: book.id }, props: { book } }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const topics = topicsForTags(book.data.tags);
const digestWordCount = String(book.body ?? '')
  .replace(/---[\s\S]*?---/, '')
  .replace(/\[[^\]]+\]\([^)]+\)/g, ' ')
  .replace(/[#*_>`-]/g, ' ')
  .trim()
  .split(/\s+/)
  .filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(digestWordCount / 200));
const seoTitle = `${book.data.title} Summary and Key Ideas`;
const seoDescription = compactDescription(
  book.data.oneLiner,
  `A self-contained summary of ${book.data.title} by ${book.data.author}.`
);

const allBooks = await getCollection('books');
const bookTitleMap = new Map(allBooks.map((entry) => [entry.id, entry.data.title]));
const answers = (await getCollection('answers'))
  .filter((a) => a.data.books.includes(book.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const answerQuestions = answers.map((answer) => answer.data.question);

const url = `https://answerwithbooks.com/books/${book.id}/`;
const bookCoverPath = fileURLToPath(new URL(`../../../public/covers/${book.id}.jpg`, import.meta.url));
const bookImage = existsSync(bookCoverPath) ? `/covers/${book.id}.jpg` : '/og.svg';
const breadcrumbs = [
  { name: 'Answer with Books', url: 'https://answerwithbooks.com/' },
  { name: 'Books', url: 'https://answerwithbooks.com/books/' },
  { name: book.data.title, url },
];
const faqs = [
  {
    question: `What is ${book.data.title} useful for?`,
    answer: book.data.readIf,
  },
  {
    question: `How does Answer with Books use ${book.data.title}?`,
    answer:
      'This page distills the book into ideas, frameworks, and source notes that can support practical answers.',
  },
  {
    question: 'Which answers draw on this book?',
    answer:
      answers.length > 0
        ? `${compactList(answerQuestions, 'Published answers')} ${answers.length === 1 ? 'draws' : 'draw'} on this book.`
        : 'No published answers draw on this book yet, but it remains available as source material for future matching.',
  },
];
const jsonLd = [
  {
    '@type': 'WebPage',
    '@id': `${url}#webpage`,
    url,
    name: `${book.data.title} by ${book.data.author}`,
    description: seoDescription,
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    primaryImageOfPage: { '@id': `${url}#primaryimage` },
  },
  {
    '@type': 'ImageObject',
    '@id': `${url}#primaryimage`,
    url: new URL(bookImage, 'https://answerwithbooks.com').href,
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    mainEntityOfPage: { '@id': `${url}#webpage` },
    headline: `${book.data.title} by ${book.data.author}, distilled into usable ideas`,
    description: seoDescription,
    image: new URL(bookImage, 'https://answerwithbooks.com').href,
    author: { '@type': 'Organization', '@id': 'https://answerwithbooks.com/#organization', name: 'Answer with Books', url: 'https://answerwithbooks.com/' },
    publisher: { '@type': 'Organization', '@id': 'https://answerwithbooks.com/#organization', name: 'Answer with Books', url: 'https://answerwithbooks.com/' },
    inLanguage: 'en',
    isAccessibleForFree: true,
    wordCount: digestWordCount,
    articleSection: book.data.tags,
    keywords: book.data.tags,
    about: { '@id': `${url}#book` },
    url,
  },
  {
    '@type': 'Book',
    '@id': `${url}#book`,
    name: book.data.title,
    author: { '@type': 'Person', name: book.data.author },
    datePublished: String(book.data.year),
    description: book.data.oneLiner,
    image: new URL(bookImage, 'https://answerwithbooks.com').href,
    url,
    workExample: answers.map((answer) => ({
      '@type': 'CreativeWork',
      name: answer.data.question,
      url: `https://answerwithbooks.com/answers/${answer.id}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url,
    })),
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title={seoTitle}
  description={seoDescription}
  path={`/books/${book.id}/`}
  image={bookImage}
  imageAlt={`${book.data.title} cover illustration`}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-5xl px-5 pt-16 pb-10">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-soft">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-accent">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/books/" class="hover:text-accent">Books</a></li>
      </ol>
    </nav>

    <header class="grid gap-8 border-b border-line pb-10 lg:grid-cols-[minmax(0,1fr)_minmax(13rem,18rem)] lg:items-start">
      <div>
        <p class="awb-eyebrow">Book digest · {digestWordCount.toLocaleString()} words · {readingMinutes} min</p>
        <h1 class="mt-3 text-wrap break-words font-serif text-4xl leading-tight sm:text-5xl">
          {book.data.title}
        </h1>
        <p class="mt-3 text-soft">
          {book.data.author}, {book.data.year}
        </p>
        <p class="mt-2 text-sm text-faint">
          Digest by <a href="/editorial/" class="underline decoration-line underline-offset-4 hover:text-ink">Answer with Books</a>
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <button
            type="button"
            data-save-book={book.id}
            data-title={book.data.title}
            class="awb-pill awb-pill-outline cursor-pointer"
          >
            Save this book
          </button>
          {topics.map((topic) => (
            <a
              href={`/topics/${topic.slug}/`}
              class="inline-flex min-h-8 items-center rounded-full border border-line px-3 py-1 text-xs text-soft font-sans hover:border-accent hover:text-accent"
            >
              {topic.label}
            </a>
          ))}
        </div>
      </div>
      <BookCover book={book} size="lg" class="justify-self-start lg:justify-self-end" priority />
    </header>

    <BookDigestPersonalizer title={book.data.title} author={book.data.author} bookUrl={url} />

    <section class="mt-6 grid gap-5 lg:grid-cols-2">
      <div class="awb-card-link p-6 text-[1rem] leading-relaxed">
        <h2 class="awb-eyebrow mb-2">
          When to reach for this book
        </h2>
        <p class="font-serif text-2xl leading-snug text-ink">{book.data.readIf}</p>
      </div>
      <div class="awb-card-link p-6 text-[1rem] leading-relaxed">
        <h2 class="awb-eyebrow mb-2">
          What the book is about
        </h2>
        <p class="font-serif text-2xl leading-snug text-ink">{book.data.oneLiner}</p>
      </div>
    </section>

    <div class="prose-awb prose-awb--aligned mt-10">
      <Content />
    </div>

    <ContentFeedback contentType="book" contentSlug={book.id} contentTitle={book.data.title} />
  </article>

  <FaqList items={faqs} eyebrow="Book Q&A" title="How this book is used" width="medium" />

  {
    answers.length > 0 && (
      <aside class="mx-auto max-w-5xl px-5 pb-16">
        <div class="border-t border-line pt-8">
          <h2 class="awb-eyebrow">
            Answers that draw on this book
          </h2>
          <div class="mt-5 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {answers.map((answer) => (
              <AnswerRow answer={answer} bookTitles={bookTitleMap} compact />
            ))}
          </div>
        </div>
      </aside>
    )
  }

  <script>
    const KEY = 'awb:saved-books';
    const btn = document.querySelector<HTMLButtonElement>('[data-save-book]');
    if (btn) {
      const slug = btn.dataset.saveBook!;
      const read = (): string[] => {
        try {
          return JSON.parse(localStorage.getItem(KEY) ?? '[]');
        } catch {
          return [];
        }
      };
      const paint = () => {
        const saved = read().includes(slug);
        btn.textContent = saved ? 'Saved - remove' : 'Save this book';
      };
      btn.addEventListener('click', () => {
        const list = read();
        const next = list.includes(slug) ? list.filter((s) => s !== slug) : [...list, slug];
        localStorage.setItem(KEY, JSON.stringify(next));
        paint();
      });
      paint();
    }
  </script>
</Base>
