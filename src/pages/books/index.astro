---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BookRow from '../../components/BookRow.astro';
import FaqList from '../../components/FaqList.astro';
import { glocal } from '../../lib/glocal';
import { faqJsonLd } from '../../lib/seo';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const url = 'https://answerwithbooks.com/books/';
const faqs = [
  {
    question: 'What is a source book on Answer with Books?',
    answer:
      'A source book is a book distilled into ideas, frameworks, and use cases that can support practical answers for Japanese and Korean readers.',
  },
  {
    question: 'Does the public book page show the full book text?',
    answer:
      'No. Public pages show distilled reader-facing notes. Heavier backend text can support matching and generation without becoming visible UI copy.',
  },
  {
    question: 'How do books connect to answers?',
    answer:
      'Answer pages cite the books they draw from, and each book page links back to the localized answers that use it.',
  },
];
const jsonLd = [
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    url,
    name: 'Answer with Books source library',
    description:
      'A source library of books distilled into mental models, frameworks, and Japan/Korea-aware applications.',
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    mainEntity: { '@id': `${url}#itemlist` },
  },
  {
    '@type': 'ItemList',
    '@id': `${url}#itemlist`,
    itemListElement: books.map((book, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: book.data.title,
      url: `https://answerwithbooks.com/books/${book.id}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Answer with Books', item: 'https://answerwithbooks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Books', item: url },
    ],
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title="Books"
  description={`The source shelf for ${glocal.audience}: books distilled into mental models, frameworks, and locally useful situations.`}
  path="/books/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-8">
    <p class="text-xs uppercase tracking-[0.18em] text-accent font-sans">Global source library</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold tracking-tight">The shelf for local questions</h1>
    <p class="mt-4 text-soft leading-relaxed max-w-2xl">
      Each page distills one book into its load-bearing ideas: the mental models worth keeping, the
      frameworks worth using, and the moments when Japanese and Korean readers should reach for it.
    </p>
  </section>
  <section class="mx-auto max-w-6xl px-5 pb-16 pt-6 border-t border-line">
    <div class="grid gap-4 md:grid-cols-2">
      {books.map((book) => <BookRow book={book} />)}
    </div>
  </section>
  <FaqList items={faqs} eyebrow="Book library Q&A" title="How the source shelf works" />
</Base>
