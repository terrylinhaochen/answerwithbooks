---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FaqList from '../../components/FaqList.astro';
import { collectTopics } from '../../lib/topics';
import { glocal } from '../../lib/glocal';
import { faqJsonLd } from '../../lib/seo';

const answers = await getCollection('answers');
const books = await getCollection('books');
const topics = collectTopics(answers, books, { includeEmpty: true });
const url = 'https://answerwithbooks.com/topics/';
const faqs = [
  {
    question: 'Why are there only a few broad topics?',
    answer:
      'The public topic map stays broad so readers can browse easily. Detailed tags and concern clusters still exist behind the scenes for retrieval and content planning.',
  },
  {
    question: 'Are these topics specific to Japan and Korea?',
    answer:
      'The topic labels are familiar global categories, but each topic description and content queue is shaped around Japanese and Korean reader demand.',
  },
  {
    question: 'How are new topic pages filled?',
    answer:
      'A topic gets more guides when local demand evidence and book-source fit are strong enough to justify publishing.',
  },
];
const jsonLd = [
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    url,
    name: 'Answer with Books topics',
    description: 'Browse Japan/Korea-aware book-grounded guides by practical topic.',
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    mainEntity: { '@id': `${url}#itemlist` },
  },
  {
    '@type': 'ItemList',
    '@id': `${url}#itemlist`,
    itemListElement: topics.map((topic, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: topic.label,
      url: `https://answerwithbooks.com/topics/${topic.slug}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Answer with Books', item: 'https://answerwithbooks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Topics', item: url },
    ],
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title="Topics"
  description={`Browse ${glocal.audience} by broad life and work topics: career, relationships, health, technology, business, negotiation, productivity, and decisions.`}
  path="/topics/"
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-8">
    <p class="text-xs uppercase tracking-[0.18em] text-accent font-sans">Localized topic map</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold tracking-tight">Topics for Japan and Korea</h1>
    <p class="mt-4 text-soft leading-relaxed max-w-2xl">
      Broad reader-facing categories. Detailed tags still help retrieval behind the scenes, but the
      public map stays simple and focused on Japanese and Korean demand.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-16 pt-6 border-t border-line">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {topics.map((topic) => (
        <a
          href={`/topics/${topic.slug}/`}
          class="rounded-md border border-line bg-white/55 p-5 shadow-sm hover:border-accent/45"
        >
          <p class="text-xs uppercase tracking-[0.16em] text-faint font-sans">
            {topic.answers.length} answers · {topic.books.length} books
          </p>
          <h2 class="mt-2 font-serif text-2xl font-semibold tracking-tight">{topic.label}</h2>
          <p class="mt-3 text-sm leading-relaxed text-soft">{topic.description}</p>
        </a>
      ))}
    </div>
  </section>
  <FaqList items={faqs} eyebrow="Topic Q&A" title="How to browse the content map" />
</Base>
