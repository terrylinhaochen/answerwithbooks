---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FaqList from '../../components/FaqList.astro';
import { collectTopics } from '../../lib/topics';
import { faqJsonLd } from '../../lib/seo';

const answers = await getCollection('answers');
const books = await getCollection('books');
const topics = collectTopics(answers, books, { includeEmpty: true });
const url = 'https://answerwithbooks.com/topics/';
const faqs = [
  {
    question: 'Why are there only a few broad topics?',
    answer:
      'The public topic map stays broad so readers can browse easily. Detailed tags and concern clusters still exist behind the scenes for retrieval and content planning.',
  },
  {
    question: 'How do topics relate to tags?',
    answer:
      'Topics are broad reader-facing categories. Detailed tags still help retrieval and content planning behind the scenes.',
  },
  {
    question: 'How are new topic pages filled?',
    answer:
      'A topic gets more guides when demand evidence and book-source fit are strong enough to justify publishing.',
  },
];
const jsonLd = [
  {
    '@type': 'CollectionPage',
    '@id': `${url}#webpage`,
    url,
    name: 'Answer with Books topics',
    description: 'Browse book-grounded guides by practical topic.',
    isPartOf: { '@id': 'https://answerwithbooks.com/#website' },
    breadcrumb: { '@id': `${url}#breadcrumb` },
    mainEntity: { '@id': `${url}#itemlist` },
  },
  {
    '@type': 'ItemList',
    '@id': `${url}#itemlist`,
    itemListElement: topics.map((topic, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: topic.label,
      url: `https://answerwithbooks.com/topics/${topic.slug}/`,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Answer with Books', item: 'https://answerwithbooks.com/' },
      { '@type': 'ListItem', position: 2, name: 'Topics', item: url },
    ],
  },
  {
    ...faqJsonLd(url, faqs),
  },
];
---

<Base
  title="Topics"
  description="Browse Answer with Books by broad life and work topics: career, relationships, health, technology, business, negotiation, productivity, and decisions."
  path="/topics/"
  jsonLd={jsonLd}
>
  <section class="awb-section pt-16 pb-8">
    <p class="awb-eyebrow">Topic map</p>
    <h1 class="awb-display mt-3 text-5xl leading-tight sm:text-6xl">Topics</h1>
    <p class="awb-copy mt-4 max-w-2xl">
      Broad reader-facing categories. Detailed tags still help retrieval behind the scenes, but the
      public map stays simple.
    </p>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-soft">
      Use topics when you know the kind of situation you are in but not the exact question to ask.
      Each category points to book-grounded guides and source books that turn recurring problems into
      sharper decision rules, better questions, and next moves you can actually test.
    </p>
  </section>

  <section class="awb-section border-t border-line pb-16 pt-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {topics.map((topic) => (
        <a
          href={`/topics/${topic.slug}/`}
          class="awb-card-link p-5"
        >
          <p class="text-xs uppercase tracking-[0.16em] text-faint font-sans">
            {topic.answers.length} answers · {topic.books.length} books
          </p>
          <h2 class="mt-2 font-serif text-2xl leading-tight">{topic.label}</h2>
          <p class="mt-3 text-sm leading-relaxed text-soft">{topic.description}</p>
          <p class="mt-4 text-sm leading-relaxed text-soft">{topic.body}</p>
        </a>
      ))}
    </div>
  </section>
  <FaqList items={faqs} eyebrow="Topic Q&A" title="How to browse the content map" width="wide" />
</Base>
