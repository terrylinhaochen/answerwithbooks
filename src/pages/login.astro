---
import Base from '../layouts/Base.astro';
---

<Base
  title="Log in"
  description="Log in to Answer with Books."
  path="/login/"
  robots="noindex, follow"
>
  <section class="mx-auto max-w-sm px-5 pt-20 pb-24">
    <h1 class="font-serif text-3xl">Log in</h1>
    <p class="mt-3 text-soft text-[0.95rem]" data-login-copy>
      Welcome back. Your <a href="/my-books/" class="text-accent underline underline-offset-4 decoration-1">saved books</a> are waiting.
    </p>

    <form id="login-form" class="mt-8 space-y-5" novalidate>
      <div>
        <label for="email" class="block text-sm font-sans text-soft mb-1.5">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="awb-input"
        />
      </div>
      <div>
        <label for="password" class="block text-sm font-sans text-soft mb-1.5">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="awb-input"
        />
      </div>
      <p id="form-message" role="alert" aria-live="polite" class="text-sm text-accent hidden"></p>
      <button
        type="submit"
        id="submit-btn"
        class="awb-pill awb-pill-primary w-full cursor-pointer"
      >
        Log in
      </button>
    </form>

    <p class="mt-6 text-sm text-soft">
      No account yet?
      <a href="/signup/" data-signup-link class="text-accent underline underline-offset-4 decoration-1">Create one</a>.
    </p>
  </section>

  <script>
    import { supabase } from '../lib/supabase';
    import { hasPendingOnboarding, persistOnboardingProfile } from '../lib/onboarding';

    const form = document.getElementById('login-form') as HTMLFormElement;
    const message = document.getElementById('form-message') as HTMLParagraphElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const loginCopy = document.querySelector<HTMLElement>('[data-login-copy]');
    const signupLink = document.querySelector<HTMLAnchorElement>('[data-signup-link]');
    const fromOnboarding = new URLSearchParams(window.location.search).get('from') === 'onboarding';
    const pendingOnboarding = fromOnboarding || hasPendingOnboarding();
    const redirectAfterAuth = pendingOnboarding ? '/profile/?onboarded=1' : '/my-books/';

    if (pendingOnboarding) {
      if (loginCopy) {
        loginCopy.textContent = 'Log in to sync the setup you just created to your profile.';
      }
      if (signupLink) signupLink.href = '/signup/?from=onboarding';
    }

    // Already logged in? Go straight to saved books.
    supabase.auth.getSession().then(({ data }) => {
      if (!data.session) return;
      if (pendingOnboarding) {
        persistOnboardingProfile(supabase, data.session).finally(() => {
          window.location.href = redirectAfterAuth;
        });
      } else {
        window.location.href = redirectAfterAuth;
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      message.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Logging in…';

      const formData = new FormData(form);
      const { data, error } = await supabase.auth.signInWithPassword({
        email: String(formData.get('email')).trim(),
        password: String(formData.get('password')),
      });

      if (error) {
        message.textContent = error.message;
        message.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Log in';
        return;
      }
      if (pendingOnboarding) await persistOnboardingProfile(supabase, data.session);
      window.location.href = redirectAfterAuth;
    });
  </script>
</Base>
