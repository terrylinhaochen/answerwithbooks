---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ActivityPanel from '../components/ActivityPanel.astro';

// Build-time book metadata, shipped as a data island for the client script.
const books = await getCollection('books');
const bookMeta = Object.fromEntries(
  books.map((b) => [b.id, { title: b.data.title, author: b.data.author }])
);
---

<Base
  title="Profile"
  description="Your saved books, question activity, and profile on Answer with Books."
  path="/my-books/"
  robots="noindex, follow"
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-24">
    <div id="library-loading" class="text-soft">Checking your session…</div>

    <div id="library-content" class="hidden">
      <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-faint font-sans">Profile</p>
          <h1 class="mt-3 max-w-lg font-serif text-5xl font-semibold leading-tight tracking-tight">
            Welcome back<span id="user-name"></span>.
          </h1>
          <p class="mt-5 max-w-lg text-lg leading-relaxed text-soft">
            This is the start of your question profile: the books you save, the answers you open,
            and the topics that keep coming back.
          </p>
          <p class="mt-7">
            <a href="/answers/" class="text-accent underline underline-offset-4 decoration-1 hover:text-accent-dark">
              Find the next answer
            </a>
          </p>
        </div>

        <ActivityPanel
          eyebrow="Your activity"
          title="Keep a visible streak of exploration."
          description="The goal is not generic reading progress. It is a trail of recurring questions, source books, and next questions the system can use to help you explore better."
        />
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <section class="rounded-md border border-line bg-paper p-5 sm:p-6">
          <h2 class="text-xs uppercase tracking-[0.18em] text-faint font-sans border-b border-line pb-3">
            Saved books
          </h2>
          <ul id="saved-list" class="divide-y divide-line"></ul>
          <p id="saved-empty" class="hidden mt-5 text-soft leading-relaxed max-w-prose">
            Nothing saved yet. Browse <a href="/books/" class="text-accent underline underline-offset-4 decoration-1">the shelf</a>
            and hit "Save this book" on any book.
          </p>
        </section>

        <section class="rounded-md border border-line bg-wash p-5 text-[0.95rem] leading-relaxed text-soft sm:p-6">
          <p class="font-sans text-xs uppercase tracking-[0.18em] text-faint">Next layer</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold leading-tight tracking-tight text-ink">
            From saved shelf to question graph.
          </h2>
          <p class="mt-3">
            The useful profile is not just books read. It should connect what you are thinking about,
            which answers helped, which books supplied the insight, and what question should come next.
          </p>
          <div class="mt-5 grid gap-3">
            {[
              'Saved answers',
              'Top-of-mind questions',
              'Source quotes and concepts',
              'Next question recommendations',
            ].map((item) => (
              <div class="border-t border-line pt-3 font-serif text-lg font-semibold text-ink">
                {item}
              </div>
            ))}
          </div>
        </section>
      </div>

      <p class="mt-10">
        <button
          type="button"
          id="signout-btn"
          class="text-sm border border-line px-4 py-1.5 rounded-sm text-soft hover:border-accent hover:text-accent transition-colors cursor-pointer"
        >
          Sign out
        </button>
      </p>
    </div>
  </section>

  <script type="application/json" id="book-meta" set:html={JSON.stringify(bookMeta)} />

  <script>
    import { supabase } from '../lib/supabase';

    const KEY = 'awb:saved-books';
    const loading = document.getElementById('library-loading')!;
    const content = document.getElementById('library-content')!;
    const userName = document.getElementById('user-name')!;
    const savedList = document.getElementById('saved-list')!;
    const savedEmpty = document.getElementById('saved-empty')!;
    const signoutBtn = document.getElementById('signout-btn')!;
    const bookMeta: Record<string, { title: string; author: string }> = JSON.parse(
      document.getElementById('book-meta')!.textContent ?? '{}'
    );

    const { data } = await supabase.auth.getSession();
    if (!data.session) {
      window.location.href = '/login/';
    } else {
      const email = data.session.user.email ?? '';
      userName.textContent = email ? `, ${email.split('@')[0]}` : '';

      let saved: string[] = [];
      try {
        saved = JSON.parse(localStorage.getItem(KEY) ?? '[]');
      } catch {
        saved = [];
      }
      const known = saved.filter((slug) => bookMeta[slug]);

      if (known.length === 0) {
        savedEmpty.classList.remove('hidden');
      } else {
        for (const slug of known) {
          const li = document.createElement('li');
          li.className = 'py-4';
          const a = document.createElement('a');
          a.href = `/books/${slug}/`;
          a.className =
            'font-serif text-lg text-ink hover:text-accent underline underline-offset-4 decoration-line hover:decoration-accent';
          a.textContent = bookMeta[slug].title;
          const span = document.createElement('span');
          span.className = 'text-sm text-faint ml-2';
          span.textContent = bookMeta[slug].author;
          li.append(a, span);
          savedList.appendChild(li);
        }
      }

      loading.classList.add('hidden');
      content.classList.remove('hidden');

      signoutBtn.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/';
      });
    }
  </script>
</Base>
