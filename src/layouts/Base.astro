---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  /** Path beginning with /, used for canonical + OG URLs */
  path?: string;
  ogType?: 'website' | 'article' | 'book';
  image?: string;
  imageAlt?: string;
  robots?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogType = 'website',
  image = '/og.svg',
  imageAlt = 'Answer with Books turns reader questions into book-grounded insights',
  robots = 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1',
  jsonLd,
} = Astro.props;
const site = 'https://answerwithbooks.com';
const canonical = new URL(path, site).href;
const fullTitle = path === '/' ? title : `${title} — Answer with Books`;
const imageUrl = new URL(image, site).href;
const structuredData = Array.isArray(jsonLd)
  ? { '@context': 'https://schema.org', '@graph': jsonLd }
  : jsonLd;
const gaMeasurementIds = (
  import.meta.env.PUBLIC_GA_MEASUREMENT_IDS ||
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID ||
  'G-FNWRC3EMV4'
)
  .split(',')
  .map((id) => id.trim())
  .filter(Boolean);
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const nav = [
  { href: '/books/', label: 'Books' },
  { href: '/answers/', label: 'Answers' },
  { href: '/skills/', label: 'Skills' },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Terry Chen" />
    <meta name="application-name" content="Answer with Books" />
    <meta name="apple-mobile-web-app-title" content="Answer with Books" />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <meta name="theme-color" content="#f5f5f5" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Answer with Books" href="/feed.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Answer with Books" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,300;6..72,400;6..72,500;6..72,600&display=swap"
    />

    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    {
      gaMeasurementIds.length > 0 && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementIds[0]}`} />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());${gaMeasurementIds
              .map((id) => `gtag('config','${id}');`)
              .join('')}`}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink">
    <header class="sticky top-0 z-40 border-b border-line bg-paper/90 backdrop-blur-xl">
      <div class="awb-header mx-auto flex min-h-16 max-w-6xl flex-wrap items-center justify-between gap-3 px-5 py-3">
        <a href="/" class="awb-brand" aria-label="Answer with Books home">Answer with Books</a>
        <div class="awb-header__actions flex min-w-0 flex-1 items-center justify-end gap-2 sm:gap-3">
          <nav aria-label="Main" class="awb-nav">
            {
              nav.map((item) => (
                <a
                  href={item.href}
                  aria-current={current.startsWith(item.href) ? 'page' : undefined}
                  class={`awb-nav__link ${current.startsWith(item.href) ? 'awb-nav__link--current' : ''}`}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <a
            href="/profile/"
            data-auth-link
            class={`awb-nav__action hidden ${current.startsWith('/profile') || current.startsWith('/my-books') || current.startsWith('/login') ? 'awb-nav__action--current' : ''}`}
          >
            Profile
          </a>
          <a
            href="/onboarding/start/"
            data-onboarding-link
            class="awb-nav__cta"
          >
            Get started
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 w-full">
      <slot />
    </main>

    <footer class="border-t border-line mt-20 bg-paper">
      <div class="mx-auto max-w-6xl px-5 py-10 text-sm text-soft">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <p>Answer with Books — books distilled into usable answers.</p>
          <a href="/editorial/" class="underline decoration-line underline-offset-4 hover:text-ink">Editorial method</a>
        </div>
      </div>
    </footer>

    <script>
      import { supabase } from '../lib/supabase';
      const activityKey = 'awb:activity';
      const today = new Date().toISOString().slice(0, 10);
      const path = window.location.pathname;
      const section = path.startsWith('/answers/')
        ? 'answers'
        : path.startsWith('/books/')
          ? 'books'
          : path.startsWith('/skills/')
            ? 'skills'
          : path.startsWith('/topics/')
            ? 'topics'
            : path.startsWith('/onboarding/')
              ? 'onboarding'
            : path.startsWith('/profile') || path.startsWith('/my-books')
              ? 'profile'
              : 'home';

      try {
        const activity = JSON.parse(localStorage.getItem(activityKey) ?? '{}');
        activity.days ||= {};
        activity.sections ||= {};
        activity.days[today] = (activity.days[today] || 0) + 1;
        activity.sections[section] = (activity.sections[section] || 0) + 1;
        activity.total = (activity.total || 0) + 1;
        activity.lastPath = path;
        activity.lastSeenAt = new Date().toISOString();
        localStorage.setItem(activityKey, JSON.stringify(activity));
        window.dispatchEvent(new CustomEvent('awb:activity-updated'));
      } catch {
        localStorage.removeItem(activityKey);
      }

      // Keep the account nav state client-side because this site is statically rendered.
      const link = document.querySelector('[data-auth-link]');
      const onboardingLink = document.querySelector('[data-onboarding-link]');
      if (link) {
        supabase.auth.getSession().then(({ data }) => {
          if (data.session) {
            link.textContent = 'Profile';
            link.classList.remove('hidden');
            onboardingLink?.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>
