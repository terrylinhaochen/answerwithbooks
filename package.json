  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:local": "rm -rf .astro dist node_modules/.astro && PATH=$HOME/.nvm/versions/node/v22.12.0/bin:$PATH astro build",
    "covers": "node scripts/generate-cover-assets.mjs --provider=gemini",
    "covers:svg": "node scripts/generate-cover-assets.mjs --provider=svg",
    "covers:prompts": "node scripts/generate-cover-assets.mjs --provider=prompts",
    "covers:gemini": "node scripts/generate-cover-assets.mjs --provider=gemini",
    "answer-covers": "node scripts/generate-answer-cover-assets.mjs --provider=gemini",
    "answer-covers:gemini": "node scripts/generate-answer-cover-assets.mjs --provider=gemini",
    "answer-covers:svg": "node scripts/generate-answer-cover-assets.mjs --provider=svg",
    "answer-covers:prompts": "node scripts/generate-answer-cover-assets.mjs --provider=prompts",
    "content:plan": "node scripts/build-content-generation-plan.mjs",
